{%- assign href = routes.root_url | append: '/products/' | append: product.handle -%}
{%- assign main = product.featured_image.url | default: product.featured_image -%}
{%- if main == blank and product.images -%}{%- assign main = product.images[0].url -%}{%- endif -%}
{%- if main == blank -%}{%- assign main = '/bazaro/img/fashion-3/product/product-1/product-1.jpg' -%}{%- endif -%}
{%- assign hover = main -%}
{%- if product.images and product.images.size > 1 -%}{%- assign hover = product.images[1].url -%}{%- endif -%}
{%- assign on_sale = false -%}
{%- if product.compare_at_price and product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
<article class="kt-card">
  <div class="kt-card-media">
    {%- if on_sale -%}<span class="kt-card-badge">Sale</span>{%- endif -%}
    <a href="{{ href }}" class="kt-card-img">
      <img class="kt-card-img-main" src="{{ main }}" alt="{{ product.title }}" loading="lazy">
      {%- if hover != main -%}<img class="kt-card-img-hover" src="{{ hover }}" alt="{{ product.title }}" loading="lazy">{%- endif -%}
    </a>
    {%- if product.id -%}
    <button type="button" class="kt-wish" data-wishlist-toggle data-product-id="{{ product.id }}" aria-label="Save to wishlist" aria-pressed="false">
      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path d="M12 20.5 5.2 13.7a4.6 4.6 0 0 1 0-6.5 4.6 4.6 0 0 1 6.5 0l.3.3.3-.3a4.6 4.6 0 0 1 6.5 6.5Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
    </button>
    {%- endif -%}
    <span class="kt-card-cta">View product</span>
  </div>
  <div class="kt-card-body">
    <h3 class="kt-card-title"><a href="{{ href }}">{{ product.title }}</a></h3>
    <div class="kt-card-price">
      {%- if on_sale -%}<span class="kt-price-old">{{ product.compare_at_price | money }}</span> <span class="kt-price-now kt-price-sale">{{ product.price | money }}</span>
      {%- else -%}<span class="kt-price-now">{{ product.price | money }}</span>{%- endif -%}
    </div>
  </div>
</article>
