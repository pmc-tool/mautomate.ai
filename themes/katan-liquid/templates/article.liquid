<nav class="kt-crumbs"><div class="kt-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><a href="{{ routes.root_url }}/blog">Journal</a><span>/</span><span class="kt-current">{{ article.title }}</span>
</div></nav>
<article class="kt-section kt-article">
  <div class="kt-container">
    <header class="kt-article-head">
      <h1 class="kt-article-title">{{ article.title }}</h1>
      <div class="kt-article-meta">
        {%- if article.author != blank -%}<span>By {{ article.author }}</span>{%- endif -%}
        {%- if article.published_at != blank -%}<span>{{ article.published_at | date: "%b %d, %Y" }}</span>{%- endif -%}
        {%- if article.reading_time -%}<span>{{ article.reading_time }} min read</span>{%- endif -%}
      </div>
    </header>
    {%- if article.cover_image != blank %}<div class="kt-article-cover"><img src="{{ article.cover_image }}" alt="{{ article.title }}"></div>{% endif -%}
    <div class="kt-article-body kt-richtext-inner">
      {%- if article.content != blank -%}{% render 'resolve-tokens', text: article.content, shop: shop %}{%- elsif article.excerpt != blank -%}<p>{{ article.excerpt }}</p>{%- endif -%}
    </div>
    <div class="kt-article-foot"><a class="kt-link" href="{{ routes.root_url }}/blog">&#8592; Back to journal</a></div>
  </div>
</article>
