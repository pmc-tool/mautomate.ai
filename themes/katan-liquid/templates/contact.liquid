{%- assign f = chrome.footer -%}
<nav class="kt-crumbs"><div class="kt-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><span class="kt-current">Contact</span>
</div></nav>
<section class="kt-section">
  <div class="kt-container">
    <div class="kt-shead kt-shead-center">
      <span class="kt-eyebrow">Get in touch</span>
      <h1 class="kt-title">Contact us</h1>
      <p class="kt-lead">Questions about an order, sizing or styling? We usually reply within a day.</p>
    </div>
    <div class="kt-contact-grid">
      <div class="kt-contact-info">
        {%- if f.contact.email != blank -%}
        <div class="kt-contact-item"><span class="kt-contact-label">Email</span><a href="mailto:{{ f.contact.email }}">{{ f.contact.email }}</a></div>
        {%- endif -%}
        {%- if f.contact.phone != blank -%}
        <div class="kt-contact-item"><span class="kt-contact-label">Phone</span><span>{{ f.contact.phone }}</span></div>
        {%- endif -%}
        <div class="kt-contact-item"><span class="kt-contact-label">Hours</span><span>Mon&ndash;Sat, 9am&ndash;6pm</span></div>
      </div>
      <form class="kt-contact-form" data-contact-form>
        <div class="kt-field-row">
          <input type="text" name="name" placeholder="Your name" aria-label="Your name" required>
          <input type="email" name="email" placeholder="Your email" aria-label="Your email" required>
        </div>
        <input type="text" name="subject" placeholder="Subject" aria-label="Subject">
        <textarea name="message" rows="6" placeholder="How can we help?" aria-label="Message" required></textarea>
        <button type="submit" class="kt-btn">Send message</button>
        <p class="kt-contact-msg" data-contact-msg hidden></p>
      </form>
    </div>
  </div>
</section>
