{%- if page.sections and page.sections.size > 0 -%}
  {%- for section in page.sections -%}{% render_section section %}{%- endfor -%}
{%- else -%}
  <section class="kt-section"><div class="kt-container kt-shead kt-shead-center"><h1 class="kt-title">{{ shop.name }}</h1><p class="kt-lead">Your storefront is ready. Add sections in the editor to build your home page.</p></div></section>
{%- endif -%}
