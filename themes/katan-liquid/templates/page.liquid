{%- comment -%} A CMS content page (about-us, faq, privacy, ...) — a block document,
  rendered exactly like the home page: the merchant's ordered sections. {%- endcomment -%}
{%- if page.sections and page.sections.size > 0 -%}
  {%- for section in page.sections -%}{% render_section section %}{%- endfor -%}
{%- else -%}
  <section class="kt-section"><div class="kt-container kt-shead kt-shead-center"><h1 class="kt-title">{{ shop.name }}</h1></div></section>
{%- endif -%}
