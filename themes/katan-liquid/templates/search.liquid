<section class="kt-section">
  <div class="kt-container">
    <div class="kt-shead kt-shead-center">
      <span class="kt-eyebrow">Find it</span>
      <h1 class="kt-title">Search</h1>
      <form class="kt-search-form" action="{{ routes.search_url }}" method="get">
        <input type="search" name="q" placeholder="Search products..." aria-label="Search products">
        <button type="submit" class="kt-btn">Search</button>
      </form>
    </div>
    <p class="kt-empty">Type above to find products across the store.</p>
  </div>
</section>
