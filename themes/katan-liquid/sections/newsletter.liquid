{%- assign s = section.settings -%}
{%- if s.title != blank -%}
<section class="kt-section kt-newsletter">
  <div class="kt-container">
    <div class="kt-newsletter-inner">
      <span class="kt-eyebrow">Newsletter</span>
      <h2 class="kt-title" data-el="heading">{{ s.title }}</h2>
      {%- if s.subtitle != blank -%}<p class="kt-newsletter-sub" data-el="text">{{ s.subtitle }}</p>{%- endif -%}
      <form class="kt-newsletter-form" data-newsletter data-el="form">
        <input type="email" placeholder="{{ s.placeholder | default: 'Enter your email address' }}" aria-label="Email address" data-el="input" required>
        <button type="submit" class="kt-btn kt-btn-gold" data-el="button">{{ s.button | default: 'Subscribe' }}</button>
      </form>
      {%- if s.provider_note != blank -%}<p class="kt-newsletter-note">{{ s.provider_note }}</p>{%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}
