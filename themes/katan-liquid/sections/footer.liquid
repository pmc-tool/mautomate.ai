{%- comment -%} Self-contained Katan footer (kt- namespace) — cream ground, ink top border, driven by the store's chrome.footer settings. {%- endcomment -%}
{%- assign root = routes.root_url -%}
{%- assign f = chrome.footer -%}
{%- assign yr = 'now' | date: '%Y' -%}
<footer class="kt-footer">
  <div class="kt-container">
    <div class="kt-footer-top">
      <div class="kt-footer-brand">
        {%- if shop.logo -%}<span class="kt-footer-logochip"><img class="kt-footer-logo" src="{{ shop.logo }}" alt="{{ shop.name }}"></span>
        {%- else -%}<div class="kt-footer-name">{{ shop.name }}</div>{%- endif -%}
        {%- if settings.footer_about != blank -%}<p class="kt-footer-about">{{ settings.footer_about }}</p>{%- endif -%}
        {%- if f.contact.email != blank -%}<a class="kt-footer-contact" href="mailto:{{ f.contact.email }}">{{ f.contact.email }}</a>{%- endif -%}
        {%- if f.contact.phone != blank -%}<span class="kt-footer-contact">{{ f.contact.phone }}</span>{%- endif -%}
        {%- if f.contact.app_buttons and f.contact.app_buttons.size > 0 -%}
        <div class="kt-footer-apps">{%- for btn in f.contact.app_buttons -%}<a href="{{ btn.href | default: '#' }}"><img src="{{ btn.img }}" alt="{{ btn.alt }}"></a>{%- endfor -%}</div>
        {%- endif -%}
      </div>

      <div class="kt-footer-col">
        <h4 class="kt-footer-title">Collections</h4>
        <ul>
          {%- if categories -%}{%- assign lim = f.column_categories.limit | default: 5 -%}
          {%- for c in categories limit: lim -%}<li><a href="{{ root }}/categories/{{ c.handle }}">{{ c.name }}</a></li>{%- endfor -%}{%- endif -%}
          {%- if f.column_categories.extra -%}{%- for item in f.column_categories.extra -%}<li><a href="{{ item.href | default: '#' }}">{{ item.label }}</a></li>{%- endfor -%}
          {%- else -%}<li><a href="{{ routes.collections_url }}">All products</a></li>{%- endif -%}
        </ul>
      </div>

      <div class="kt-footer-col">
        <h4 class="kt-footer-title">About the store</h4>
        <ul>
          {%- if f.column_links and f.column_links.size > 0 -%}{%- for item in f.column_links -%}<li><a href="{{ item.href | default: '#' }}">{{ item.label }}</a></li>{%- endfor -%}
          {%- else -%}<li><a href="{{ root }}/about-us">About us</a></li><li><a href="{{ root }}/contact">Contact</a></li><li><a href="{{ root }}/blog">Journal</a></li>{%- endif -%}
        </ul>
      </div>

      <div class="kt-footer-col kt-footer-col-wide">
        <h4 class="kt-footer-title">Stay in touch</h4>
        {%- if f.social and f.social.size > 0 -%}
        <div class="kt-footer-social">
          {%- for s in f.social -%}<a href="{{ s.href | default: '#' }}" aria-label="social"><i class="fab {{ s.icon }}"></i></a>{%- endfor -%}
        </div>
        {%- endif -%}
        <form class="kt-footer-news" data-newsletter>
          <input type="email" placeholder="{{ f.newsletter.placeholder | default: 'Your email address' }}" aria-label="Email">
          <button type="submit" aria-label="Subscribe"><i class="fas fa-arrow-right"></i></button>
        </form>
      </div>
    </div>

    <div class="kt-footer-bottom">
      <p class="kt-footer-copy">{%- if f.copyright != blank -%}{%- assign _copy = f.copyright | replace: '{year}', yr -%}{% render 'resolve-tokens', text: _copy, shop: shop %}{%- else -%}&copy; {{ yr }} {{ shop.name }}. {{ settings.footer_copyright | default: 'All rights reserved.' }}{%- endif -%}</p>
      {%- if f.payment_image != blank -%}<img class="kt-footer-pay" src="{{ f.payment_image }}" alt="Payment methods">{%- endif -%}
    </div>
  </div>
</footer>
