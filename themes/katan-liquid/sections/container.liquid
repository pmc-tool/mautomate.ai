{%- assign cols = section.settings.columns -%}
{%- if cols and cols.size > 0 -%}
<section class="kt-section kt-composed">
  <div class="kt-container">
    <div class="kt-composed-row" data-cols="{{ cols.size }}">
      {%- for col in cols -%}
      <div class="kt-composed-col">
        {%- for w in col.widgets -%}
        <div class="kt-composed-widget">
          {%- if w.image != blank -%}<img class="kt-composed-img" src="{{ w.image }}" alt="{{ w.title | default: '' }}">{%- endif -%}
          {%- if w.eyebrow != blank -%}<span class="kt-eyebrow">{{ w.eyebrow }}</span>{%- endif -%}
          {%- if w.title != blank -%}<h3 class="kt-composed-title">{{ w.title }}</h3>{%- endif -%}
          {%- if w.html != blank -%}<div class="kt-richtext-inner">{% render 'resolve-tokens', text: w.html, shop: shop %}</div>{%- endif -%}
          {%- if w.body != blank -%}<p class="kt-composed-body">{{ w.body }}</p>{%- endif -%}
          {%- if w.cta.href != blank and w.cta.label != blank -%}<a class="kt-link" href="{{ w.cta.href }}">{{ w.cta.label }}</a>{%- endif -%}
        </div>
        {%- endfor -%}
      </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
