{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="kt-section kt-testi">
  <div class="kt-container">
    <div class="kt-shead kt-shead-center">
      <span class="kt-eyebrow">Testimonials</span>
      <h2 class="kt-title" data-el="title">{{ s.title | default: 'What our customers say' }}</h2>
    </div>
    <div class="kt-testi-grid">
      {%- for item in items -%}
      <figure class="kt-testi-card" data-el-item="items:{{ forloop.index0 }}" data-el="item">
        <div class="kt-testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        {%- if item.quote != blank -%}<blockquote class="kt-testi-quote" data-el="quote">{{ item.quote }}</blockquote>{%- endif -%}
        <figcaption class="kt-testi-author" data-el="author">
          {%- if item.avatar != blank %}<img src="{{ item.avatar }}" alt="{{ item.author }}">{% endif -%}
          <span class="kt-testi-meta"><span class="kt-testi-name">{{ item.author }}</span>{% if item.role != blank %}<span class="kt-testi-role">{{ item.role }}</span>{% endif %}</span>
        </figcaption>
      </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
