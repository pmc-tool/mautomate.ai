{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="kt-section kt-showcase{% if section.in_column %} kt-in-column{% endif %}">
  <div class="kt-container">
    <div class="kt-shead kt-shead-center">
      {%- if s.sub_title != blank -%}<span class="kt-eyebrow">{{ s.sub_title }}</span>{%- endif -%}
      {%- if s.title != blank -%}<h2 class="kt-title" data-el="title">{{ s.title }}</h2>{%- endif -%}
    </div>
    <div class="kt-showcase-grid">
      {%- for item in items -%}
      <a class="kt-showcase-tile" href="{{ item.href | default: '/store' }}" data-el-item="items:{{ forloop.index0 }}" data-el="tile">
        <span class="kt-showcase-img" data-el="image">{% if item.image != blank %}<img src="{{ item.image }}" alt="{{ item.label }}">{% endif %}</span>
        <span class="kt-showcase-label" data-el="label">{{ item.label }}</span>
        {%- if item.count != blank -%}<span class="kt-showcase-count">{{ item.count }} items</span>{%- endif -%}
      </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

