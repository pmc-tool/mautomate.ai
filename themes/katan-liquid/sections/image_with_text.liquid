{%- assign s = section.settings -%}
{%- assign nl = '
' -%}
{%- if s.image != blank or s.title != blank -%}
<section class="kt-section kt-imgtext{% if s.image_side == 'right' %} kt-imgtext-right{% endif %}">
  <div class="kt-container">
    <div class="kt-imgtext-grid">
      <div class="kt-imgtext-media" data-el="image">{% if s.image != blank %}<img src="{{ s.image }}" alt="{{ s.title }}">{% endif %}</div>
      <div class="kt-imgtext-body">
        {%- if s.eyebrow != blank -%}<span class="kt-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.title != blank -%}<h2 class="kt-title" data-el="heading">{%- assign lines = s.title | split: nl -%}{%- for line in lines -%}{{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}{%- endfor -%}</h2>{%- endif -%}
        {%- if s.body != blank -%}<p class="kt-imgtext-copy" data-el="text">{{ s.body }}</p>{%- endif -%}
        {%- if s.cta.href != blank and s.cta.label != blank -%}<a class="kt-btn" href="{{ s.cta.href }}" data-el="button">{{ s.cta.label }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>
{%- endif -%}
