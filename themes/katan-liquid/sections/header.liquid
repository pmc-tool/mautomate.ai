{%- assign root = routes.root_url -%}
{%- if settings.show_announcement and settings.announcement_text != blank -%}
<div class="kt-announce"><div class="kt-container"><p>{{ settings.announcement_text }}</p></div></div>
{%- endif -%}

<header class="kt-header" data-header>
  <div class="kt-container kt-header-inner">
    <a class="kt-logo" href="{{ root }}">
      {%- if shop.logo -%}<img src="{{ shop.logo }}" alt="{{ shop.name }}">
      {%- else -%}<span class="kt-logo-text">{{ shop.name }}</span>{%- endif -%}
    </a>

    <nav class="kt-nav" aria-label="Primary">
      <a href="{{ root }}">Home</a>
      <div class="kt-nav-drop">
        <a href="{{ routes.collections_url }}">Shop</a>
        {%- if categories and categories.size > 0 -%}
        <div class="kt-dropdown">
          <a href="{{ routes.collections_url }}">All products</a>
          {%- for c in categories limit: 12 -%}<a href="{{ root }}/categories/{{ c.handle }}">{{ c.name }}</a>{%- endfor -%}
        </div>
        {%- endif -%}
      </div>
      <a href="{{ root }}/blog">Journal</a>
      <a href="{{ root }}/contact">Contact</a>
    </nav>

    <div class="kt-header-actions">
      <a class="kt-icon" href="{{ routes.search_url }}" aria-label="Search">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="1.5"/></svg>
      </a>
      <a class="kt-icon" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><circle cx="12" cy="8" r="3.6" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 20c0-4 3.6-6 7.5-6s7.5 2 7.5 6" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      </a>
      <a class="kt-icon kt-cart" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 8h14l-1 12H6L5 8z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M9 8V6a3 3 0 0 1 6 0v2" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        {%- if cart.item_count > 0 -%}<span class="kt-cart-count">{{ cart.item_count }}</span>{%- endif -%}
      </a>
      <button class="kt-burger" data-nav-toggle aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </div>

  <nav class="kt-mobile-nav" data-mobile-nav aria-label="Mobile">
    <a href="{{ root }}">Home</a>
    <a href="{{ routes.collections_url }}">Shop</a>
    {%- if categories -%}{%- for c in categories limit: 12 -%}<a href="{{ root }}/categories/{{ c.handle }}">{{ c.name }}</a>{%- endfor -%}{%- endif -%}
    <a href="{{ root }}/blog">Journal</a>
    <a href="{{ root }}/contact">Contact</a>
    <a href="{{ routes.account_url }}">Account</a>
  </nav>
</header>
