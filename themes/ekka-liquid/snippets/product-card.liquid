{%- assign href = routes.root_url | append: '/products/' | append: product.handle -%}
{%- assign main = product.featured_image.url | default: product.featured_image -%}
{%- if main == blank and product.images -%}{%- assign main = product.images[0].url -%}{%- endif -%}
{%- if main == blank -%}{%- assign main = '/ekka/images/product-image/6_1.jpg' -%}{%- endif -%}
{%- assign hover = main -%}
{%- if product.images and product.images.size > 1 -%}{%- assign hover = product.images[1].url -%}{%- endif -%}
{%- assign on_sale = false -%}
{%- if product.compare_at_price and product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
<article class="ek-card">
  <div class="ek-card-media">
    <a href="{{ href }}" class="ek-card-img">
      <img class="ek-card-img-main" src="{{ main }}" alt="{{ product.title }}" loading="lazy">
      {%- if hover != main -%}<img class="ek-card-img-hover" src="{{ hover }}" alt="{{ product.title }}" loading="lazy">{%- endif -%}
    </a>
    {%- if on_sale -%}<span class="ek-card-flags"><span class="ek-flag-sale">Sale</span></span>{%- endif -%}
    <div class="ek-card-actions">
      <a href="{{ href }}" class="ek-card-act" title="Quick view" aria-label="View product"><i class="fas fa-eye"></i></a>
      <a href="{{ href }}" class="ek-card-act ek-card-act-main" title="Add to cart"><i class="fas fa-shopping-basket"></i> Add To Cart</a>
      <a href="{{ href }}" class="ek-card-act" title="Details" aria-label="Product details"><i class="far fa-heart"></i></a>
    </div>
  </div>
  <div class="ek-card-body">
    <h3 class="ek-card-title"><a href="{{ href }}">{{ product.title }}</a></h3>
    <div class="ek-card-price">
      {%- if on_sale -%}<span class="ek-price-old">{{ product.compare_at_price | money }}</span> <span class="ek-price-new">{{ product.price | money }}</span>
      {%- else -%}<span class="ek-price-new">{{ product.price | money }}</span>{%- endif -%}
    </div>
  </div>
</article>
