{%- assign s = section.settings -%}
{%- assign images = s.images -%}
{%- if images and images.size > 0 -%}
<section class="ek-section ek-gallery">
  <div class="ek-container">
    {%- if s.title != blank -%}
    <div class="ek-stitle">
      <h2 class="ek-bg-title" aria-hidden="true">{{ s.title }}</h2>
      <h2 class="ek-title">{{ s.title }}</h2>
    </div>
    {%- endif -%}
    <div class="ek-gallery-grid">
      {%- for item in images -%}
        {%- assign src = item.image | default: item -%}
        {%- if src != blank -%}
        <figure class="ek-gallery-cell"><img src="{{ src }}" alt="{{ item.alt | default: 'Gallery image' }}">{% if item.caption != blank %}<figcaption>{{ item.caption }}</figcaption>{% endif %}</figure>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
