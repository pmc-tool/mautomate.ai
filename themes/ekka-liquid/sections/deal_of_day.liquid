{%- assign s = section.settings -%}
<section class="ek-section ek-deal">
  <div class="ek-container">
    <div class="ek-stitle ek-stitle-left">
      <h2 class="ek-bg-title" aria-hidden="true">Limited Time Offer</h2>
      <h2 class="ek-title">Limited Time Offer</h2>
    </div>
    <div class="ek-deal-card">
      <div class="ek-deal-media">
        {%- if s.image %}<img src="{{ s.image }}" alt="{{ s.title | default: 'Deal of the day' }}">{% else %}<div class="ek-deal-fallback"></div>{% endif -%}
      </div>
      <div class="ek-deal-content">
        <h3 class="ek-deal-title">{{ s.title | default: 'Deal of the day' }}</h3>
        <div class="ek-countdown" data-countdown="{{ s.countdown_to }}">
          <div class="ek-cd"><span class="ek-cd-num" data-cd="days">00</span><span class="ek-cd-lbl">Days</span></div>
          <div class="ek-cd"><span class="ek-cd-num" data-cd="hours">00</span><span class="ek-cd-lbl">Hours</span></div>
          <div class="ek-cd"><span class="ek-cd-num" data-cd="minutes">00</span><span class="ek-cd-lbl">Minutes</span></div>
          <div class="ek-cd"><span class="ek-cd-num" data-cd="seconds">00</span><span class="ek-cd-lbl">Seconds</span></div>
        </div>
        {%- if s.description != blank -%}<p class="ek-deal-desc">{{ s.description }}</p>{%- endif -%}
        {%- if s.cta.href != blank -%}<a class="ek-btn" href="{{ s.cta.href }}">{{ s.cta.label | default: 'Shop Now' }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>
