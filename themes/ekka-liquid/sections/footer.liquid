{%- comment -%} Self-contained Ekka footer (ek- namespace), driven by the store's chrome.footer settings. {%- endcomment -%}
{%- assign root = routes.root_url -%}
{%- assign f = chrome.footer -%}
{%- assign yr = 'now' | date: '%Y' -%}
<footer class="ek-footer">
  <div class="ek-footer-top">
    <div class="ek-container">
      <div class="ek-footer-grid">
        <div class="ek-footer-brand">
          {%- if shop.logo -%}<a href="{{ root }}" class="ek-footer-logo"><img src="{{ shop.logo }}" alt="{{ shop.name }}"></a>
          {%- else -%}<div class="ek-footer-name">{{ shop.name }}</div>{%- endif -%}
          {%- if settings.footer_about != blank -%}<p class="ek-footer-about">{{ settings.footer_about }}</p>{%- endif -%}
          <ul class="ek-footer-contactlist">
            {%- if f.contact.phone != blank -%}<li><span>Call Us:</span> {{ f.contact.phone }}</li>{%- endif -%}
            {%- if f.contact.email != blank -%}<li><span>Email:</span> <a href="mailto:{{ f.contact.email }}">{{ f.contact.email }}</a></li>{%- endif -%}
          </ul>
          {%- if f.contact.app_buttons and f.contact.app_buttons.size > 0 -%}
          <div class="ek-footer-apps">{%- for btn in f.contact.app_buttons -%}<a href="{{ btn.href | default: '#' }}"><img src="{{ btn.img }}" alt="{{ btn.alt }}"></a>{%- endfor -%}</div>
          {%- endif -%}
        </div>

        <div class="ek-footer-col">
          <h4 class="ek-footer-title">Categories</h4>
          <ul>
            {%- if categories -%}{%- assign lim = f.column_categories.limit | default: 5 -%}
            {%- for c in categories limit: lim -%}<li><a href="{{ root }}/categories/{{ c.handle }}">{{ c.name }}</a></li>{%- endfor -%}{%- endif -%}
            {%- if f.column_categories.extra -%}{%- for item in f.column_categories.extra -%}<li><a href="{{ item.href | default: '#' }}">{{ item.label }}</a></li>{%- endfor -%}
            {%- else -%}<li><a href="{{ routes.collections_url }}">All products</a></li>{%- endif -%}
          </ul>
        </div>

        <div class="ek-footer-col">
          <h4 class="ek-footer-title">Account</h4>
          <ul>
            <li><a href="{{ routes.account_url }}">My Account</a></li>
            <li><a href="{{ routes.cart_url }}">Cart</a></li>
            <li><a href="{{ routes.collections_url }}">Shop</a></li>
            <li><a href="{{ root }}/contact">Contact</a></li>
          </ul>
        </div>

        <div class="ek-footer-col">
          <h4 class="ek-footer-title">Information</h4>
          <ul>
            {%- if f.column_links and f.column_links.size > 0 -%}{%- for item in f.column_links -%}<li><a href="{{ item.href | default: '#' }}">{{ item.label }}</a></li>{%- endfor -%}
            {%- else -%}<li><a href="{{ root }}/about-us">About us</a></li><li><a href="{{ root }}/contact">Contact</a></li><li><a href="{{ root }}/blog">Blog</a></li>{%- endif -%}
          </ul>
        </div>

        <div class="ek-footer-col ek-footer-newscol">
          <h4 class="ek-footer-title">{{ f.newsletter.title | default: 'Newsletter' }}</h4>
          <p class="ek-footer-newstext">Get instant updates about our new products and special promos!</p>
          <form class="ek-subscribe" data-newsletter>
            <input type="email" placeholder="{{ f.newsletter.placeholder | default: 'Enter your email here...' }}" aria-label="Email" required>
            <button type="submit" aria-label="{{ f.newsletter.button | default: 'Subscribe' }}"><i class="far fa-paper-plane"></i></button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="ek-footer-bottom">
    <div class="ek-container ek-footer-bottom-inner">
      <div class="ek-footer-social">
        <span class="ek-topbar-label">Follow us on:</span>
        {%- if f.social and f.social.size > 0 -%}
          {%- for s in f.social -%}<a href="{{ s.href | default: '#' }}" aria-label="social"><i class="fab {{ s.icon }}"></i></a>{%- endfor -%}
        {%- endif -%}
      </div>
      <p class="ek-footer-copy">{%- if f.copyright != blank -%}{{ f.copyright | replace: '{year}', yr }}{%- else -%}&copy; {{ yr }} {{ shop.name }}. {{ settings.footer_copyright | default: 'All rights reserved.' }}{%- endif -%}</p>
      <div class="ek-footer-pay">
        {%- if f.payment_image != blank -%}<img src="{{ f.payment_image }}" alt="Payment methods">{%- endif -%}
      </div>
    </div>
  </div>
</footer>
