<div class="ek-breadband">
  <div class="ek-container">
    <h1 class="ek-breadband-title">From Our Blog</h1>
    <nav class="ek-crumbs"><a href="{{ routes.root_url }}">Home</a><span>/</span><span class="ek-current">Blog</span></nav>
  </div>
</div>
<section class="ek-section">
  <div class="ek-container">
    {%- assign posts = blog.posts -%}
    {%- if posts and posts.size > 0 -%}
    <div class="ek-blog-grid">
      {%- for post in posts -%}
      <article class="ek-blog-card">
        <a class="ek-blog-cover" href="{{ routes.root_url }}/blog/{{ post.slug }}">
          {%- if post.cover_image %}<img src="{{ post.cover_image }}" alt="{{ post.title }}" loading="lazy">{% else %}<span class="ek-blog-cover-ph"></span>{% endif -%}
        </a>
        <div class="ek-blog-body">
          {%- if post.published_at != blank -%}<span class="ek-blog-date">{{ post.published_at | date: "%b %d, %Y" }}</span>{%- endif -%}
          <h2 class="ek-blog-title"><a href="{{ routes.root_url }}/blog/{{ post.slug }}">{{ post.title }}</a></h2>
          {%- if post.excerpt != blank -%}<p class="ek-blog-excerpt">{{ post.excerpt }}</p>{%- endif -%}
          <a class="ek-link" href="{{ routes.root_url }}/blog/{{ post.slug }}">Read more</a>
        </div>
      </article>
      {%- endfor -%}
    </div>
    {%- else -%}
    <p class="ek-empty">No posts yet — check back soon.</p>
    {%- endif -%}
  </div>
</section>
