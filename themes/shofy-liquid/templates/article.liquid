<div class="sf-pagehead">
  <div class="sf-container">
    <h1 class="sf-pagehead-title">{{ article.title }}</h1>
    <nav class="sf-pagehead-crumbs"><a href="{{ routes.root_url }}">Home</a><span>/</span><a href="{{ routes.root_url }}/blog">Blog</a><span>/</span><span class="sf-current">{{ article.title }}</span></nav>
  </div>
</div>
<article class="sf-section sf-article">
  <div class="sf-container">
    <header class="sf-article-head">
      <div class="sf-article-meta">
        {%- if article.author != blank -%}<span>By {{ article.author }}</span>{%- endif -%}
        {%- if article.published_at != blank -%}<span>{{ article.published_at | date: "%b %d, %Y" }}</span>{%- endif -%}
        {%- if article.reading_time -%}<span>{{ article.reading_time }} min read</span>{%- endif -%}
      </div>
    </header>
    {%- if article.cover_image %}<div class="sf-article-cover"><img src="{{ article.cover_image }}" alt="{{ article.title }}"></div>{% endif -%}
    <div class="sf-article-body sf-richtext-inner">
      {%- if article.content != blank -%}{% render 'resolve-tokens', text: article.content, shop: shop %}{%- elsif article.excerpt != blank -%}<p>{{ article.excerpt }}</p>{%- endif -%}
    </div>
    <div class="sf-article-foot"><a class="sf-link" href="{{ routes.root_url }}/blog">&#8592; Back to blog</a></div>
  </div>
</article>
