{%- if page.sections and page.sections.size > 0 -%}
  {%- for section in page.sections -%}{% render_section section %}{%- endfor -%}
{%- else -%}
  <section class="sf-section"><div class="sf-container sf-shead sf-shead-center"><h1 class="sf-title">{{ shop.name }}</h1><p class="sf-lead">Your storefront is ready. Add sections in the editor to build your home page.</p></div></section>
{%- endif -%}
