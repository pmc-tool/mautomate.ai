<div class="sf-pagehead">
  <div class="sf-container">
    <h1 class="sf-pagehead-title">From our blog</h1>
    <nav class="sf-pagehead-crumbs"><a href="{{ routes.root_url }}">Home</a><span>/</span><span class="sf-current">Blog</span></nav>
  </div>
</div>
<section class="sf-section">
  <div class="sf-container">
    {%- assign posts = blog.posts -%}
    {%- if posts and posts.size > 0 -%}
    <div class="sf-blog-grid">
      {%- for post in posts -%}
      <article class="sf-blog-card">
        <a class="sf-blog-cover" href="{{ routes.root_url }}/blog/{{ post.slug }}">
          {%- if post.cover_image %}<img src="{{ post.cover_image }}" alt="{{ post.title }}" loading="lazy">{% else %}<span class="sf-blog-cover-ph"></span>{% endif -%}
        </a>
        <div class="sf-blog-body">
          {%- if post.published_at != blank -%}<span class="sf-blog-date">{{ post.published_at | date: "%b %d, %Y" }}</span>{%- endif -%}
          <h2 class="sf-blog-title"><a href="{{ routes.root_url }}/blog/{{ post.slug }}">{{ post.title }}</a></h2>
          {%- if post.excerpt != blank -%}<p class="sf-blog-excerpt">{{ post.excerpt }}</p>{%- endif -%}
          <a class="sf-link" href="{{ routes.root_url }}/blog/{{ post.slug }}">Read More <i class="fas fa-arrow-right"></i></a>
        </div>
      </article>
      {%- endfor -%}
    </div>
    {%- else -%}
    <p class="sf-empty">No posts yet — check back soon.</p>
    {%- endif -%}
  </div>
</section>
