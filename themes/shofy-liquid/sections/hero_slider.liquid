{%- assign slides = section.settings.slides -%}
{%- assign nl = '
' -%}
{%- if slides and slides.size > 0 -%}
<section class="sf-hero" data-slider data-autoplay="{{ section.settings.autoplay_ms | default: 5000 }}">
  <div class="sf-hero-slides">
    {%- for slide in slides -%}
    <div class="sf-hero-slide{% if forloop.first %} is-active{% endif %}" data-slide>
      <div class="sf-hero-shapes" aria-hidden="true">
        <img class="sf-hero-shape-1" src="/shofy/img/slider/shape/slider-shape-1.png" alt="">
        <img class="sf-hero-shape-2" src="/shofy/img/slider/shape/slider-shape-2.png" alt="">
        <img class="sf-hero-shape-3" src="/shofy/img/slider/shape/slider-shape-3.png" alt="">
      </div>
      <div class="sf-container sf-hero-inner">
        <div class="sf-hero-content">
          {%- if slide.subtitle != blank -%}<span class="sf-hero-sub">{{ slide.subtitle }}</span>{%- endif -%}
          <h1 class="sf-hero-title">{%- assign lines = slide.title | split: nl -%}{%- for line in lines -%}{{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}{%- endfor -%}</h1>
          {%- assign cta_label = slide.cta.label | default: 'Shop Now' -%}
          {%- if slide.cta.href != blank and cta_label != blank -%}<a class="sf-btn sf-btn-white" href="{{ slide.cta.href }}">{{ cta_label }} <i class="fas fa-arrow-right"></i></a>{%- endif -%}
        </div>
        <div class="sf-hero-thumb">
          {%- if slide.image != blank -%}<img src="{{ slide.image }}" alt="{{ slide.title }}">{%- endif -%}
        </div>
      </div>
    </div>
    {%- endfor -%}
  </div>
  {%- if slides.size > 1 -%}
  <div class="sf-hero-dots" data-slider-dots>
    {%- for slide in slides -%}<button class="sf-hero-dot{% if forloop.first %} is-active{% endif %}" data-slider-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>{%- endfor -%}
  </div>
  {%- endif -%}
</section>
{%- endif -%}
