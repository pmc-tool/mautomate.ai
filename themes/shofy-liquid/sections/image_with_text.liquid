{%- assign s = section.settings -%}
{%- assign nl = '
' -%}
{%- if s.image != blank or s.title != blank -%}
<section class="sf-section sf-imgtext-wrap">
  <div class="sf-container">
    <div class="sf-imgtext{% if s.image_side == 'left' %} sf-imgtext-left{% endif %}">
      <div class="sf-imgtext-body">
        {%- if s.eyebrow != blank -%}<span class="sf-imgtext-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.title != blank -%}<h2 class="sf-imgtext-title">{%- assign lines = s.title | split: nl -%}{%- for line in lines -%}{{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}{%- endfor -%}</h2>{%- endif -%}
        {%- if s.body != blank -%}<p class="sf-imgtext-copy">{{ s.body }}</p>{%- endif -%}
        {%- if s.cta.href != blank -%}<a class="sf-btn sf-btn-white" href="{{ s.cta.href }}">{{ s.cta.label | default: 'Shop now' }} <i class="fas fa-arrow-right"></i></a>{%- endif -%}
      </div>
      <div class="sf-imgtext-media">{% if s.image %}<img src="{{ s.image }}" alt="{{ s.title }}">{% endif %}</div>
    </div>
  </div>
</section>
{%- endif -%}
