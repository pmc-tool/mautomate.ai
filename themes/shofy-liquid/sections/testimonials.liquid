{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="sf-section sf-testi" data-slider data-autoplay="7000">
  <div class="sf-container">
    {%- if s.title != blank -%}
    <div class="sf-shead sf-shead-center"><h2 class="sf-title sf-title-sm">{{ s.title }}</h2></div>
    {%- endif -%}
    <div class="sf-testi-slides">
      {%- for item in items -%}
      <figure class="sf-testi-item{% if forloop.first %} is-active{% endif %}" data-slide>
        <div class="sf-testi-stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
        {%- if item.quote != blank -%}<blockquote class="sf-testi-quote">&ldquo;{{ item.quote }}&rdquo;</blockquote>{%- endif -%}
        <figcaption class="sf-testi-user">
          {%- if item.avatar -%}<img src="{{ item.avatar }}" alt="{{ item.author }}">{%- endif -%}
          <span class="sf-testi-meta"><span class="sf-testi-name">{{ item.author }}</span>{% if item.role != blank %}<span class="sf-testi-role">{{ item.role }}</span>{% endif %}</span>
        </figcaption>
      </figure>
      {%- endfor -%}
    </div>
    {%- if items.size > 1 -%}
    <div class="sf-testi-dots" data-slider-dots>
      {%- for item in items -%}<button class="sf-testi-dot{% if forloop.first %} is-active{% endif %}" data-slider-dot="{{ forloop.index0 }}" aria-label="Testimonial {{ forloop.index }}"></button>{%- endfor -%}
    </div>
    {%- endif -%}
  </div>
</section>
{%- endif -%}
