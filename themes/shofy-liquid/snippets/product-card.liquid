{%- assign href = routes.root_url | append: '/products/' | append: product.handle -%}
{%- assign main = product.featured_image.url | default: product.featured_image -%}
{%- if main == blank and product.images -%}{%- assign main = product.images[0].url -%}{%- endif -%}
{%- assign hover = main -%}
{%- if product.images and product.images.size > 1 -%}{%- assign hover = product.images[1].url -%}{%- endif -%}
{%- assign on_sale = false -%}
{%- if product.compare_at_price and product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
<article class="sf-card">
  <div class="sf-card-media">
    {%- if on_sale -%}<span class="sf-card-badge">Sale</span>{%- endif -%}
    <a href="{{ href }}" class="sf-card-img">
      {%- if main != blank -%}
      <img class="sf-card-img-main" src="{{ main }}" alt="{{ product.title }}" loading="lazy">
      {%- if hover != main -%}<img class="sf-card-img-hover" src="{{ hover }}" alt="{{ product.title }}" loading="lazy">{%- endif -%}
      {%- else -%}
      <span class="sf-card-img-ph"></span>
      {%- endif -%}
    </a>
    <div class="sf-card-actions">
      <a href="{{ href }}" class="sf-card-action" aria-label="Add to cart"><i class="fas fa-shopping-cart"></i></a>
      <a href="{{ href }}" class="sf-card-action" aria-label="Quick view"><i class="far fa-eye"></i></a>
    </div>
  </div>
  <div class="sf-card-body">
    <h3 class="sf-card-title"><a href="{{ href }}">{{ product.title }}</a></h3>
    <div class="sf-card-rating"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
    <div class="sf-card-price">
      {%- if on_sale -%}<span class="sf-price-old">{{ product.compare_at_price | money }}</span> <span class="sf-price-now">{{ product.price | money }}</span>
      {%- else -%}<span class="sf-price-now">{{ product.price | money }}</span>{%- endif -%}
    </div>
  </div>
</article>
