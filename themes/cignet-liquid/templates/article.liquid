<nav class="cg-crumbs"><div class="cg-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><a href="{{ routes.root_url }}/blog">Blog</a><span>/</span><span class="cg-current">{{ article.title }}</span>
</div></nav>
<article class="cg-section cg-article">
  <div class="cg-container">
    <header class="cg-article-head">
      <h1 class="cg-article-title">{{ article.title }}</h1>
      <div class="cg-article-meta">
        {%- if article.author != blank -%}<span>By {{ article.author }}</span>{%- endif -%}
        {%- if article.published_at != blank -%}<span>{{ article.published_at | date: "%b %d, %Y" }}</span>{%- endif -%}
        {%- if article.reading_time -%}<span>{{ article.reading_time }} min read</span>{%- endif -%}
      </div>
    </header>
    {%- if article.cover_image != blank -%}<div class="cg-article-cover"><img src="{{ article.cover_image }}" alt="{{ article.title }}"></div>{%- endif -%}
    <div class="cg-article-body cg-richtext-inner">
      {%- if article.content != blank -%}{% render 'resolve-tokens', text: article.content, shop: shop %}{%- elsif article.excerpt != blank -%}<p>{{ article.excerpt }}</p>{%- endif -%}
    </div>
    <div class="cg-article-foot"><a class="cg-link" href="{{ routes.root_url }}/blog">&#8592; Back to blog</a></div>
  </div>
</article>
