<div class="cg-pagehead">
  <div class="cg-container">
    <h1 class="cg-pagehead-title">{{ collection.title }}</h1>
    <nav class="cg-pagehead-crumbs"><a href="{{ routes.root_url }}">Home</a><span>/</span><a href="{{ routes.collections_url }}">Shop</a><span>/</span><span class="cg-current">{{ collection.title }}</span></nav>
  </div>
</div>
<section class="cg-section">
  <div class="cg-container">
    <div class="cg-shead cg-shead-center">
      {%- if collection.description != blank -%}<p class="cg-lead">{{ collection.description }}</p>{%- endif -%}
      <span class="cg-count">{{ collection.products_count }} products</span>
    </div>
    {%- if collection.products and collection.products.size > 0 -%}
    <div class="cg-grid">{%- for product in collection.products -%}{% render 'product-card', product: product %}{%- endfor -%}</div>
    {%- else -%}<p class="cg-empty">No products in this collection yet.</p>{%- endif -%}
  </div>
</section>
