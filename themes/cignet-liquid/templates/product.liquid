{%- assign p = product -%}
<nav class="cg-crumbs"><div class="cg-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><a href="{{ routes.collections_url }}">Shop</a><span>/</span><span class="cg-current">{{ p.title }}</span>
</div></nav>

<section class="cg-section cg-pdp">
  <div class="cg-container">
    <div class="cg-pdp-grid">
      <div class="cg-pdp-gallery">
        {%- assign main = p.featured_image.url | default: p.featured_image -%}
        {%- if main == blank -%}{%- assign main = '/cignet/images/product-image-1.png' -%}{%- endif -%}
        <div class="cg-pdp-main"><img id="pdp-main-img" src="{{ main }}" alt="{{ p.title }}"></div>
        {%- if p.images and p.images.size > 1 -%}
        <div class="cg-pdp-thumbs" data-pdp-thumbs>
          {%- for image in p.images -%}<button class="cg-pdp-thumb{% if forloop.first %} is-active{% endif %}" data-full="{{ image.url }}"><img src="{{ image.url }}" alt="{{ image.alt | default: p.title }}"></button>{%- endfor -%}
        </div>
        {%- endif -%}
      </div>

      <div class="cg-pdp-info">
        <h1 class="cg-pdp-title">{{ p.title }}</h1>
        <div class="cg-pdp-price">
          {%- if p.compare_at_price and p.compare_at_price > p.price -%}<span class="cg-price-now">{{ p.price | money }}</span> <span class="cg-price-old">{{ p.compare_at_price | money }}</span>
          {%- else -%}<span class="cg-price-now">{{ p.price | money }}</span>{%- endif -%}
        </div>
        {%- if p.available -%}<span class="cg-pdp-stock in">In stock</span>{%- else -%}<span class="cg-pdp-stock out">Out of stock</span>{%- endif -%}
        {%- if p.description != blank -%}<div class="cg-pdp-desc"><p>{{ p.description }}</p></div>{%- endif -%}

        {%- for option in p.options -%}
        <div class="cg-pdp-opt"><span class="cg-pdp-opt-name">{{ option.name }}</span><div class="cg-pdp-opt-vals">{%- for value in option.values -%}<span class="cg-swatch">{{ value }}</span>{%- endfor -%}</div></div>
        {%- endfor -%}

        <form class="cg-pdp-cart" data-add-to-cart>
          {%- if p.variants and p.variants.size > 1 -%}
          <div class="cg-pdp-opt"><span class="cg-pdp-opt-name">Variant</span>
            <select class="cg-select" data-variant-select>
              {%- for v in p.variants -%}<option value="{{ v.id }}" {% unless v.available %}disabled{% endunless %}>{{ v.title }} &mdash; {{ v.price | money }}{% unless v.available %} (sold out){% endunless %}</option>{%- endfor -%}
            </select>
          </div>
          {%- elsif p.variants and p.variants.size == 1 -%}
          <input type="hidden" data-variant-select value="{{ p.variants[0].id }}">
          {%- endif -%}
          <div class="cg-pdp-buy">
            <input type="number" class="cg-qty" data-qty value="1" min="1" aria-label="Quantity">
            <button type="submit" class="cg-btn cg-btn-solid" data-add-btn {% unless p.available %}disabled{% endunless %}>{% if p.available %}Add to cart{% else %}Sold out{% endif %}</button>
          </div>
          <p class="cg-pdp-msg" data-cart-msg hidden></p>
        </form>
      </div>
    </div>
  </div>
</section>
