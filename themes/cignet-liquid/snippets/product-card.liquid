{%- assign href = routes.root_url | append: '/products/' | append: product.handle -%}
{%- assign main = product.featured_image.url | default: product.featured_image -%}
{%- if main == blank and product.images -%}{%- assign main = product.images[0].url -%}{%- endif -%}
{%- if main == blank -%}{%- assign main = '/cignet/images/product-image-1.png' -%}{%- endif -%}
{%- assign hover = main -%}
{%- if product.images and product.images.size > 1 -%}{%- assign hover = product.images[1].url -%}{%- endif -%}
{%- assign on_sale = false -%}
{%- if product.compare_at_price and product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
<article class="cg-card">
  <div class="cg-card-media">
    {%- if on_sale -%}<span class="cg-card-badge">Sale</span>{%- endif -%}
    <a href="{{ href }}" class="cg-card-img">
      <img class="cg-card-img-main" src="{{ main }}" alt="{{ product.title }}" loading="lazy">
      {%- if hover != main -%}<img class="cg-card-img-hover" src="{{ hover }}" alt="{{ product.title }}" loading="lazy">{%- endif -%}
    </a>
  </div>
  <div class="cg-card-body">
    <h3 class="cg-card-title"><a href="{{ href }}">{{ product.title }}</a></h3>
    <div class="cg-card-price">
      {%- if on_sale -%}<span class="cg-price-now">{{ product.price | money }}</span> <span class="cg-price-old">{{ product.compare_at_price | money }}</span>
      {%- else -%}<span class="cg-price-now">{{ product.price | money }}</span>{%- endif -%}
    </div>
  </div>
</article>
