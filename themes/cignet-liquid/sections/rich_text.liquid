{%- assign s = section.settings -%}
{%- assign width = s.width | default: 'normal' -%}
<section class="cg-section cg-richtext cg-richtext-{{ width }}">
  <div class="cg-container">
    <div class="cg-richtext-inner">{%- if s.html != blank -%}{% render 'resolve-tokens', text: s.html, shop: shop %}{%- endif -%}</div>
  </div>
</section>
