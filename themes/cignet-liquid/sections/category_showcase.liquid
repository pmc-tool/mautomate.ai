{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="cg-section cg-showcase">
  <div class="cg-container">
    <div class="cg-showcase-head">
      <div class="cg-shead">
        {%- if s.sub_title != blank -%}<span class="cg-eyebrow">{{ s.sub_title }}</span>{%- endif -%}
        {%- if s.title != blank -%}<h2 class="cg-title">{{ s.title }}</h2>{%- endif -%}
      </div>
      <a class="cg-btn cg-showcase-btn" href="{{ routes.collections_url }}">View all collection</a>
    </div>
    <div class="cg-showcase-grid">
      {%- for item in items -%}
      <a class="cg-showcase-tile" href="{{ item.href | default: '/store' }}">
        <span class="cg-showcase-img">{% if item.image != blank %}<img src="{{ item.image }}" alt="{{ item.label }}">{% endif %}</span>
        <span class="cg-showcase-label">{{ item.label }}</span>
        {%- if item.count != blank -%}<span class="cg-showcase-count">{{ item.count }} items</span>{%- endif -%}
      </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
