{%- assign s = section.settings -%}
<section class="cg-section cg-deal">
  <div class="cg-container">
    <div class="cg-deal-card">
      {%- if s.image != blank -%}<img class="cg-deal-bg" src="{{ s.image }}" alt="{{ s.title | default: 'Limited offer' }}">{%- endif -%}
      <div class="cg-deal-body">
        <span class="cg-deal-kicker">Limited time offer</span>
        <h2 class="cg-deal-title">{{ s.title | default: 'Deal of the day' }}</h2>
        {%- if s.description != blank -%}<p class="cg-deal-desc">{{ s.description }}</p>{%- endif -%}
        <div class="cg-countdown" data-countdown="{{ s.countdown_to }}">
          <div class="cg-cd"><span class="cg-cd-num" data-cd="days">00</span><span class="cg-cd-lbl">Days</span></div>
          <span class="cg-cd-sep">:</span>
          <div class="cg-cd"><span class="cg-cd-num" data-cd="hours">00</span><span class="cg-cd-lbl">Hours</span></div>
          <span class="cg-cd-sep">:</span>
          <div class="cg-cd"><span class="cg-cd-num" data-cd="minutes">00</span><span class="cg-cd-lbl">Mins</span></div>
          <span class="cg-cd-sep">:</span>
          <div class="cg-cd"><span class="cg-cd-num" data-cd="seconds">00</span><span class="cg-cd-lbl">Secs</span></div>
        </div>
        {%- if s.cta.href != blank -%}<a class="cg-btn cg-btn-light" href="{{ s.cta.href }}">{{ s.cta.label | default: 'Shop now' }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>
