{%- assign tabs = section.settings.tabs -%}
{%- if tabs and tabs.size > 0 -%}
<section class="cg-section cg-tabs" data-tabs>
  <div class="cg-container">
    <div class="cg-shead cg-shead-center">
      <span class="cg-eyebrow">Our products</span>
      <nav class="cg-tabnav" role="tablist">
        {%- for tab in tabs -%}
        <button class="cg-tabbtn{% if forloop.first %} is-active{% endif %}" data-tab-btn="{{ forloop.index0 }}" role="tab">{{ tab.label }}</button>
        {%- endfor -%}
      </nav>
    </div>
    {%- for tab in tabs -%}
    <div class="cg-tabpanel{% if forloop.first %} is-active{% endif %}" data-tab-panel="{{ forloop.index0 }}" role="tabpanel">
      {%- assign products = tab.products -%}
      {%- if products and products.size > 0 -%}
      <div class="cg-grid">{%- for product in products -%}{% render 'product-card', product: product %}{%- endfor -%}</div>
      {%- else -%}
      <p class="cg-empty">No products to show here yet.</p>
      {%- endif -%}
    </div>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}
