{%- assign slides = section.settings.slides -%}
{%- assign nl = '
' -%}
{%- if slides and slides.size > 0 -%}
<section class="cg-hero" data-hero data-autoplay="{{ section.settings.autoplay_ms | default: 6000 }}">
  <div class="cg-hero-slides">
    {%- for slide in slides -%}
    <div class="cg-hero-slide{% if forloop.first %} is-active{% endif %}"{% if slide.image != blank %} style="background-image:url('{{ slide.image }}')"{% endif %}>
      <div class="cg-container cg-hero-inner">
        <div class="cg-hero-content">
          {%- if slide.subtitle != blank -%}<span class="cg-eyebrow cg-eyebrow-light">{{ slide.subtitle }}</span>{%- endif -%}
          <h1 class="cg-hero-title">{%- assign lines = slide.title | split: nl -%}{%- for line in lines -%}{{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}{%- endfor -%}</h1>
          {%- if slide.cta.href != blank -%}<a class="cg-btn cg-btn-light" href="{{ slide.cta.href }}">{{ slide.cta.label | default: 'Shop now' }}</a>{%- endif -%}
        </div>
      </div>
    </div>
    {%- endfor -%}
  </div>
  {%- if slides.size > 1 -%}
  <button class="cg-hero-arrow cg-hero-prev" data-hero-prev aria-label="Previous">&#8249;</button>
  <button class="cg-hero-arrow cg-hero-next" data-hero-next aria-label="Next">&#8250;</button>
  <div class="cg-hero-dots" data-hero-dots>
    {%- for slide in slides -%}<button class="cg-hero-dot{% if forloop.first %} is-active{% endif %}" data-hero-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>{%- endfor -%}
  </div>
  {%- endif -%}
</section>
{%- endif -%}
