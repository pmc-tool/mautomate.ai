{%- assign cols = section.settings.columns -%}
{%- if cols and cols.size > 0 -%}
<section class="cg-section cg-composed">
  <div class="cg-container">
    <div class="cg-composed-row" data-cols="{{ cols.size }}">
      {%- for col in cols -%}
      <div class="cg-composed-col">
        {%- for w in col.widgets -%}
        <div class="cg-composed-widget">
          {%- if w.image != blank -%}<img class="cg-composed-img" src="{{ w.image }}" alt="{{ w.title | default: '' }}">{%- endif -%}
          {%- if w.eyebrow != blank -%}<span class="cg-eyebrow">{{ w.eyebrow }}</span>{%- endif -%}
          {%- if w.title != blank -%}<h3 class="cg-composed-title">{{ w.title }}</h3>{%- endif -%}
          {%- if w.html != blank -%}<div class="cg-richtext-inner">{% render 'resolve-tokens', text: w.html, shop: shop %}</div>{%- endif -%}
          {%- if w.body != blank -%}<p class="cg-composed-body">{{ w.body }}</p>{%- endif -%}
          {%- if w.cta.href != blank -%}<a class="cg-link" href="{{ w.cta.href }}">{{ w.cta.label | default: 'Learn more' }}</a>{%- endif -%}
        </div>
        {%- endfor -%}
      </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
