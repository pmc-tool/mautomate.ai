{%- assign s = section.settings -%}
{%- if s.title != blank -%}
<section class="bz-section bz-newsletter">
  <div class="bz-container">
    <div class="bz-newsletter-inner">
      <span class="bz-subtitle">Newsletter</span>
      <h2 class="bz-title">{{ s.title }}</h2>
      {%- if s.subtitle != blank -%}<p class="bz-newsletter-sub">{{ s.subtitle }}</p>{%- endif -%}
      <form class="bz-newsletter-form" data-newsletter>
        <input type="email" placeholder="{{ s.placeholder | default: 'Enter your email address' }}" aria-label="Email address" required>
        <button type="submit" class="bz-newsletter-btn">{{ s.button | default: 'Subscribe' }}</button>
      </form>
      {%- if s.provider_note != blank -%}<p class="bz-newsletter-note">{{ s.provider_note }}</p>{%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}
