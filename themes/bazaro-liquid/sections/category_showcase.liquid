{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="bz-section bz-showcase">
  <div class="bz-container">
    <div class="bz-showcase-head">
      <div>
        {%- if s.sub_title != blank -%}<span class="bz-subtitle">{{ s.sub_title }}</span>{%- endif -%}
        {%- if s.title != blank -%}<h2 class="bz-title">{{ s.title }}</h2>{%- endif -%}
      </div>
      <a class="bz-link" href="{{ routes.collections_url }}">View all Collection</a>
    </div>
    <div class="bz-showcase-grid">
      {%- for item in items -%}
      <a class="bz-showcase-tile" href="{{ item.href | default: '/store' }}">
        <span class="bz-showcase-img">{% if item.image != blank %}<img src="{{ item.image }}" alt="{{ item.label }}">{% endif %}</span>
        <span class="bz-showcase-caption">
          <span class="bz-showcase-meta">
            <span class="bz-showcase-label">{{ item.label }}</span>
            {%- if item.count != blank -%}<span class="bz-showcase-count">{{ item.count }} items</span>{%- endif -%}
          </span>
          <span class="bz-showcase-arrow" aria-hidden="true">
            <svg viewBox="0 0 12 12" width="12" height="12"><path d="M.75 5.75h10m0 0-5-5m5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </span>
      </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
