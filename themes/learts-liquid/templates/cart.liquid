<nav class="lz-crumbs"><div class="lz-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><span class="lz-current">Cart</span>
</div></nav>
<section class="lz-section lz-cart-page" data-cart-page>
  <div class="lz-container">
    <div class="lz-shead"><h1 class="lz-title">Your cart</h1></div>
    {%- if cart.items and cart.items.size > 0 -%}
    <div class="lz-cart-layout">
      <div class="lz-cart-lines">
        <div class="lz-cart-row lz-cart-head"><span>Product</span><span>Price</span><span>Qty</span><span>Total</span><span></span></div>
        {%- for item in cart.items -%}
        <div class="lz-cart-row" data-cart-line="{{ item.id }}">
          <div class="lz-cart-prod">
            {%- if item.image %}<img src="{{ item.image }}" alt="{{ item.title }}">{% endif -%}
            <div>
              <a href="{{ routes.root_url }}{{ item.url }}" class="lz-cart-name">{{ item.title }}</a>
              {%- if item.variant.title != blank and item.variant.title != "Default Variant" -%}
              <span class="lz-cart-variant">{{ item.variant.title }}</span>
              {%- endif -%}
            </div>
          </div>
          <span>{{ item.unit_price | money }}</span>
          <span class="lz-qty">
            <button type="button" data-qty-minus aria-label="Decrease quantity">&minus;</button>
            <input type="text" inputmode="numeric" value="{{ item.quantity }}" data-qty-input aria-label="Quantity">
            <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
          </span>
          <span>{{ item.line_price | money }}</span>
          <button type="button" class="lz-cart-remove" data-line-remove aria-label="Remove {{ item.title }}">&times;</button>
        </div>
        {%- endfor -%}
        <p class="lz-cart-msg" data-cart-msg hidden></p>
      </div>
      <aside class="lz-cart-summary">
        <h2 class="lz-cart-summary-title">Summary</h2>
        <div class="lz-cart-sum-row"><span>Subtotal</span><span>{{ cart.subtotal_price | money }}</span></div>
        {%- if cart.discount_total > 0 -%}
        <div class="lz-cart-sum-row lz-cart-discount"><span>Discount</span><span>&minus;{{ cart.discount_total | money }}</span></div>
        {%- endif -%}
        <div class="lz-cart-sum-row lz-cart-total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
        <form class="lz-promo" data-promo-form>
          <input type="text" name="code" placeholder="Promo code" autocomplete="off" aria-label="Promo code">
          <button type="submit">Apply</button>
        </form>
        {%- for promo in cart.promotions -%}
          {%- if promo.code != blank and promo.is_automatic != true -%}
          <div class="lz-promo-tag">
            <span>{{ promo.code }}</span>
            <button type="button" data-promo-remove="{{ promo.code }}" aria-label="Remove code {{ promo.code }}">&times;</button>
          </div>
          {%- endif -%}
        {%- endfor -%}
        <p class="lz-cart-msg" data-promo-msg hidden></p>
        <a class="lz-btn lz-btn-block" href="{{ cart.checkout_url }}">Checkout</a>
        <a class="lz-cart-continue" href="{{ routes.collections_url }}">Continue shopping</a>
      </aside>
    </div>
    {%- else -%}
    <div class="lz-cart-empty"><p>Your cart is empty.</p><a class="lz-btn" href="{{ routes.collections_url }}">Start shopping</a></div>
    {%- endif -%}
  </div>
</section>
