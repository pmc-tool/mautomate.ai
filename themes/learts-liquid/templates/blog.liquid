<nav class="lz-crumbs"><div class="lz-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><span class="lz-current">Blog</span>
</div></nav>
<section class="lz-section">
  <div class="lz-container">
    <div class="lz-shead lz-shead-center">
      <span class="lz-eyebrow">Journal</span>
      <h1 class="lz-title">From our blog</h1>
    </div>
    {%- assign posts = blog.posts -%}
    {%- if posts and posts.size > 0 -%}
    <div class="lz-blog-grid">
      {%- for post in posts -%}
      <article class="lz-blog-card">
        <a class="lz-blog-cover" href="{{ routes.root_url }}/blog/{{ post.slug }}">
          {%- if post.cover_image %}<img src="{{ post.cover_image }}" alt="{{ post.title }}" loading="lazy">{% else %}<span class="lz-blog-cover-ph"></span>{% endif -%}
        </a>
        <div class="lz-blog-body">
          {%- if post.published_at != blank -%}<span class="lz-blog-date">{{ post.published_at | date: "%b %d, %Y" }}</span>{%- endif -%}
          <h2 class="lz-blog-title"><a href="{{ routes.root_url }}/blog/{{ post.slug }}">{{ post.title }}</a></h2>
          {%- if post.excerpt != blank -%}<p class="lz-blog-excerpt">{{ post.excerpt }}</p>{%- endif -%}
          <a class="lz-link" href="{{ routes.root_url }}/blog/{{ post.slug }}">Read more</a>
        </div>
      </article>
      {%- endfor -%}
    </div>
    {%- else -%}
    <p class="lz-empty">No posts yet — check back soon.</p>
    {%- endif -%}
  </div>
</section>
