{%- if page.sections and page.sections.size > 0 -%}
  {%- for section in page.sections -%}{% render_section section %}{%- endfor -%}
{%- else -%}
  <section class="lz-section"><div class="lz-container lz-shead lz-shead-center"><h1 class="lz-title">{{ shop.name }}</h1><p class="lz-lead">Your storefront is ready. Add sections in the editor to build your home page.</p></div></section>
{%- endif -%}
