{%- assign f = chrome.footer -%}
<nav class="lz-crumbs"><div class="lz-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><span class="lz-current">Contact</span>
</div></nav>
<section class="lz-section">
  <div class="lz-container">
    <div class="lz-shead lz-shead-center">
      <span class="lz-eyebrow">Get in touch</span>
      <h1 class="lz-title">Contact us</h1>
      <p class="lz-lead">Questions about an order or a custom piece? We usually reply within a day.</p>
    </div>
    <div class="lz-contact-grid">
      <div class="lz-contact-info">
        {%- if f.contact.email != blank -%}
        <div class="lz-contact-item"><span class="lz-contact-label">Email</span><a href="mailto:{{ f.contact.email }}">{{ f.contact.email }}</a></div>
        {%- endif -%}
        {%- if f.contact.phone != blank -%}
        <div class="lz-contact-item"><span class="lz-contact-label">Phone</span><span>{{ f.contact.phone }}</span></div>
        {%- endif -%}
        <div class="lz-contact-item"><span class="lz-contact-label">Hours</span><span>Mon–Sat, 9am–6pm</span></div>
      </div>
      <form class="lz-contact-form" data-contact-form>
        <div class="lz-field-row">
          <input type="text" name="name" placeholder="Your name" aria-label="Your name" required>
          <input type="email" name="email" placeholder="Your email" aria-label="Your email" required>
        </div>
        <input type="text" name="subject" placeholder="Subject" aria-label="Subject">
        <textarea name="message" rows="6" placeholder="How can we help?" aria-label="Message" required></textarea>
        <button type="submit" class="lz-btn">Send message</button>
        <p class="lz-contact-msg" data-contact-msg hidden></p>
      </form>
    </div>
  </div>
</section>
