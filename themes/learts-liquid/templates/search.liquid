<section class="lz-section">
  <div class="lz-container">
    <div class="lz-shead lz-shead-center">
      <span class="lz-eyebrow">Find it</span>
      <h1 class="lz-title">Search</h1>
      <form class="lz-search-form" action="{{ routes.search_url }}" method="get">
        <input type="search" name="q" placeholder="Search products..." aria-label="Search products">
        <button type="submit" class="lz-btn">Search</button>
      </form>
    </div>
    <p class="lz-empty">Type above to find products across the store.</p>
  </div>
</section>
