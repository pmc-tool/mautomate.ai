{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="lz-section lz-showcase">
  <div class="lz-container">
    <div class="lz-shead lz-shead-center">
      {%- if s.sub_title != blank -%}<span class="lz-eyebrow">{{ s.sub_title }}</span>{%- endif -%}
      {%- if s.title != blank -%}<h2 class="lz-title">{{ s.title }}</h2>{%- endif -%}
    </div>
    <div class="lz-showcase-grid">
      {%- for item in items -%}
      <a class="lz-showcase-tile" href="{{ item.href | default: '/store' }}">
        <span class="lz-showcase-img">{% if item.image %}<img src="{{ item.image }}" alt="{{ item.label }}">{% endif %}</span>
        <span class="lz-showcase-label">{{ item.label }}</span>
        {%- if item.count != blank -%}<span class="lz-showcase-count">{{ item.count }} items</span>{%- endif -%}
      </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
