{%- assign s = section.settings -%}
{%- assign images = s.images -%}
{%- if images and images.size > 0 -%}
<section class="lz-section lz-insta">
  <div class="lz-container">
    {%- if s.heading != blank or s.handle != blank -%}
    <div class="lz-shead lz-shead-center">
      {%- if s.heading != blank -%}<span class="lz-eyebrow">{{ s.heading }}</span>{%- endif -%}
      {%- if s.handle != blank -%}<h2 class="lz-title">{{ s.handle }}</h2>{%- endif -%}
    </div>
    {%- endif -%}
    <div class="lz-insta-grid">
      {%- for item in images -%}{%- if item.image != blank -%}
      <a class="lz-insta-cell" href="{{ item.href | default: '#' }}"><img src="{{ item.image }}" alt="Instagram post"><span class="lz-insta-ic"><i class="fab fa-instagram"></i></span></a>
      {%- endif -%}{%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
