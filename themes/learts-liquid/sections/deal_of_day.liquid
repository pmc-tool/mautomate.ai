{%- assign s = section.settings -%}
<section class="lz-section lz-deal">
  <div class="lz-container">
    <div class="lz-deal-grid">
      <div class="lz-deal-media">
        {%- if s.image %}<img src="{{ s.image }}" alt="{{ s.title | default: 'Deal of the day' }}">{% else %}<div class="lz-deal-fallback"></div>{% endif -%}
      </div>
      <div class="lz-deal-content">
        <span class="lz-eyebrow">Limited time</span>
        <h2 class="lz-title">{{ s.title | default: 'Deal of the day' }}</h2>
        {%- if s.description != blank -%}<p class="lz-deal-desc">{{ s.description }}</p>{%- endif -%}
        <div class="lz-countdown" data-countdown="{{ s.countdown_to }}">
          <div class="lz-cd"><span class="lz-cd-num" data-cd="days">00</span><span class="lz-cd-lbl">Days</span></div>
          <div class="lz-cd"><span class="lz-cd-num" data-cd="hours">00</span><span class="lz-cd-lbl">Hours</span></div>
          <div class="lz-cd"><span class="lz-cd-num" data-cd="minutes">00</span><span class="lz-cd-lbl">Mins</span></div>
          <div class="lz-cd"><span class="lz-cd-num" data-cd="seconds">00</span><span class="lz-cd-lbl">Secs</span></div>
        </div>
        {%- if s.cta.href != blank -%}<a class="lz-btn" href="{{ s.cta.href }}">{{ s.cta.label | default: 'Shop now' }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>
