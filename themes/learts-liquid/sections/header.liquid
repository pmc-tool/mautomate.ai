{%- assign root = routes.root_url -%}
{%- if settings.show_announcement and settings.announcement_text != blank -%}
<div class="lz-announce"><div class="lz-container"><p>{{ settings.announcement_text }}</p></div></div>
{%- endif -%}

<header class="lz-header" data-header>
  <div class="lz-container lz-header-inner">
    <a class="lz-logo" href="{{ root }}">
      {%- if shop.logo -%}<img src="{{ shop.logo }}" alt="{{ shop.name }}">
      {%- else -%}<span class="lz-logo-text">{{ shop.name }}</span>{%- endif -%}
    </a>

    <nav class="lz-nav" aria-label="Primary">
      <a href="{{ root }}">Home</a>
      <div class="lz-nav-drop">
        <a href="{{ routes.collections_url }}">Shop</a>
        {%- if categories and categories.size > 0 -%}
        <div class="lz-dropdown">
          <a href="{{ routes.collections_url }}">All products</a>
          {%- for c in categories limit: 12 -%}<a href="{{ root }}/categories/{{ c.handle }}">{{ c.name }}</a>{%- endfor -%}
        </div>
        {%- endif -%}
      </div>
      <a href="{{ root }}/blog">Blog</a>
      <a href="{{ root }}/contact">Contact</a>
    </nav>

    <div class="lz-header-actions">
      <a class="lz-icon" href="{{ routes.search_url }}" aria-label="Search">
        <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true"><circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="1.5"/></svg>
      </a>
      <a class="lz-icon" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true"><circle cx="12" cy="8" r="3.6" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 20c0-4 3.6-6 7.5-6s7.5 2 7.5 6" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
      </a>
      <a class="lz-icon lz-cart" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" width="19" height="19" aria-hidden="true"><path d="M6 7h13l-1.4 10.2a2 2 0 0 1-2 1.8H9.4a2 2 0 0 1-2-1.8L6 7z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M9 7a3 3 0 0 1 6 0" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
        {%- if cart.item_count > 0 -%}<span class="lz-cart-count">{{ cart.item_count }}</span>{%- endif -%}
      </a>
      <button class="lz-burger" data-nav-toggle aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </div>

  <nav class="lz-mobile-nav" data-mobile-nav aria-label="Mobile">
    <a href="{{ root }}">Home</a>
    <a href="{{ routes.collections_url }}">Shop</a>
    {%- if categories -%}{%- for c in categories -%}<a href="{{ root }}/categories/{{ c.handle }}">{{ c.name }}</a>{%- endfor -%}{%- endif -%}
    <a href="{{ root }}/blog">Blog</a>
    <a href="{{ root }}/contact">Contact</a>
    <a href="{{ routes.account_url }}">Account</a>
  </nav>
</header>
