{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="lz-section lz-testi">
  <div class="lz-container">
    <div class="lz-shead lz-shead-center">
      <span class="lz-eyebrow">Testimonials</span>
      <h2 class="lz-title">{{ s.title | default: 'What our customers say' }}</h2>
    </div>
    <div class="lz-testi-grid">
      {%- for item in items -%}
      <figure class="lz-testi-card">
        <div class="lz-testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        {%- if item.quote != blank -%}<blockquote class="lz-testi-quote">{{ item.quote }}</blockquote>{%- endif -%}
        <figcaption class="lz-testi-author">
          {%- if item.avatar %}<img src="{{ item.avatar }}" alt="{{ item.author }}">{% endif -%}
          <span class="lz-testi-meta"><span class="lz-testi-name">{{ item.author }}</span>{% if item.role != blank %}<span class="lz-testi-role">{{ item.role }}</span>{% endif %}</span>
        </figcaption>
      </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
