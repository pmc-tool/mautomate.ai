<!doctype html>
<html lang="{{ request.locale | default: 'en' }}">
<head>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Questrial&family=Raleway:wght@700;900&display=swap" rel="stylesheet">
  {%- comment -%} Font Awesome (shared vendor file) is used only for the social /
     instagram icons. No Exzo template CSS is loaded - this theme is fully
     self-contained in theme.css (ex- namespace), so nothing leaks global
     html/body rules. {%- endcomment -%}
  <link rel="stylesheet" href="/learts/assets/css/vendor/fontawesome.min.css">
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  <style>
    :root{
      --ex-accent: {{ settings.accent_color | default: '#b8cd06' }};
      --ex-container: {{ settings.container_width | default: 1380 }}px;
    }
  </style>
</head>
<body class="template-{{ template }} ex-body">
  {% section 'header' %}
  <main id="main">
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
