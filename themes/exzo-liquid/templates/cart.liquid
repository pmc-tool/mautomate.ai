<nav class="ex-crumbs"><div class="ex-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><span class="ex-current">Cart</span>
</div></nav>
<section class="ex-section ex-cartpage">
  <div class="ex-container">
    <div class="ex-shead"><h1 class="ex-title">Your bag</h1><span class="ex-underline ex-underline-left"><span></span></span></div>
    {%- if cart.items and cart.items.size > 0 -%}
    <div class="ex-cart-layout">
      <div class="ex-cart-lines">
        <div class="ex-cart-row ex-cart-head"><span>Product</span><span>Price</span><span>Qty</span><span>Total</span></div>
        {%- for item in cart.items -%}
        <div class="ex-cart-row">
          <div class="ex-cart-prod">
            {%- if item.image != blank %}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}">{% endif -%}
            <div><a href="{{ routes.root_url }}{{ item.url }}" class="ex-cart-name">{{ item.title }}</a>{% if item.variant.title != blank %}<span class="ex-cart-variant">{{ item.variant.title }}</span>{% endif %}</div>
          </div>
          <span>{{ item.line_price | money }}</span>
          <span>{{ item.quantity }}</span>
          <span>{{ item.line_price | money }}</span>
        </div>
        {%- endfor -%}
      </div>
      <aside class="ex-cart-summary">
        <h2 class="ex-cart-summary-title">Summary</h2>
        <div class="ex-cart-sum-row"><span>Subtotal</span><span>{{ cart.subtotal_price | money }}</span></div>
        <div class="ex-cart-sum-row ex-cart-total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
        <a class="ex-btn ex-btn-block" href="{{ cart.checkout_url }}">Checkout</a>
        <a class="ex-cart-continue" href="{{ routes.collections_url }}">Continue shopping</a>
      </aside>
    </div>
    {%- else -%}
    <div class="ex-cart-empty"><p>Your bag is empty.</p><a class="ex-btn" href="{{ routes.collections_url }}">Start shopping</a></div>
    {%- endif -%}
  </div>
</section>
