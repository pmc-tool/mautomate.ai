<nav class="ex-crumbs"><div class="ex-container">
  <a href="{{ routes.root_url }}">Home</a><span>/</span><span class="ex-current">Cart</span>
</div></nav>
<section class="ex-section ex-cartpage" data-cart-page>
  <div class="ex-container">
    <div class="ex-shead">
      <h1 class="ex-title">Your bag</h1>
      <span class="ex-underline ex-underline-left"><span></span></span>
      {%- if cart.item_count > 0 -%}
      <span class="ex-count">{{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %} in your bag</span>
      {%- endif -%}
    </div>
    {%- if cart.items and cart.items.size > 0 -%}
    <div class="ex-bag-layout">
      <div class="ex-bag-lines">
        {%- for item in cart.items -%}
        <article class="ex-bag-line" data-cart-line="{{ item.id }}">
          <a class="ex-bag-thumb" href="{{ routes.root_url }}{{ item.url }}">
            {%- if item.image != blank -%}
            <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}">
            {%- else -%}
            <span class="ex-bag-thumb-ph"></span>
            {%- endif -%}
          </a>
          <div class="ex-bag-info">
            <a class="ex-bag-name" href="{{ routes.root_url }}{{ item.url }}">{{ item.title }}</a>
            {%- if item.variant.title != blank and item.variant.title != "Default Variant" -%}
            <span class="ex-bag-variant">{{ item.variant.title }}</span>
            {%- endif -%}
            <span class="ex-bag-unit">{{ item.unit_price | money }} each</span>
          </div>
          <div class="ex-bag-ctrls">
            <span class="ex-bag-qty">
              <button type="button" data-qty-minus aria-label="Decrease quantity">&minus;</button>
              <input type="text" inputmode="numeric" value="{{ item.quantity }}" data-qty-input aria-label="Quantity">
              <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
            </span>
            <span class="ex-bag-total">{{ item.line_price | money }}</span>
            <button type="button" class="ex-bag-remove" data-line-remove aria-label="Remove {{ item.title }}">&times;</button>
          </div>
        </article>
        {%- endfor -%}
        <p class="ex-bag-msg" data-cart-msg hidden></p>
      </div>
      <aside class="ex-bag-summary">
        <h2 class="ex-bag-summary-title">Order summary</h2>
        <span class="ex-underline ex-underline-left ex-bag-summary-rule"><span></span></span>
        <div class="ex-bag-sum-row"><span>Subtotal</span><span>{{ cart.subtotal_price | money }}</span></div>
        {%- if cart.discount_total > 0 -%}
        <div class="ex-bag-sum-row ex-bag-discount"><span>Discount</span><span>&minus;{{ cart.discount_total | money }}</span></div>
        {%- endif -%}
        <div class="ex-bag-sum-row ex-bag-grand"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
        <form class="ex-bag-promo" data-promo-form>
          <input type="text" name="code" placeholder="Promo code" autocomplete="off" aria-label="Promo code">
          <button type="submit">Apply</button>
        </form>
        {%- for promo in cart.promotions -%}
          {%- if promo.code != blank and promo.is_automatic != true -%}
          <div class="ex-bag-promo-tag">
            <span>{{ promo.code }}</span>
            <button type="button" data-promo-remove="{{ promo.code }}" aria-label="Remove code {{ promo.code }}">&times;</button>
          </div>
          {%- endif -%}
        {%- endfor -%}
        <p class="ex-bag-msg" data-promo-msg hidden></p>
        <a class="ex-btn ex-btn-block" href="{{ cart.checkout_url }}">Checkout</a>
        <a class="ex-bag-continue" href="{{ routes.collections_url }}">Continue shopping</a>
      </aside>
    </div>
    {%- else -%}
    <div class="ex-cart-empty"><p>Your bag is empty.</p><a class="ex-btn" href="{{ routes.collections_url }}">Start shopping</a></div>
    {%- endif -%}
  </div>
</section>
