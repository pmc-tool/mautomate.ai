{%- if page.sections and page.sections.size > 0 -%}
  {%- for section in page.sections -%}{% render_section section %}{%- endfor -%}
{%- else -%}
  <section class="ex-section"><div class="ex-container ex-shead ex-shead-center"><h1 class="ex-title">{{ shop.name }}</h1><span class="ex-underline"><span></span></span><p class="ex-lead">Your storefront is ready. Add sections in the editor to build your home page.</p></div></section>
{%- endif -%}
