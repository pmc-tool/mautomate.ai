<section class="ex-section">
  <div class="ex-container">
    <div class="ex-shead ex-shead-center">
      <span class="ex-eyebrow">Find it</span>
      <h1 class="ex-title">Search</h1>
      <span class="ex-underline"><span></span></span>
      <form class="ex-search-form" action="{{ routes.search_url }}" method="get">
        <input type="search" name="q" placeholder="Enter keyword" aria-label="Search products">
        <button type="submit" class="ex-btn">Search</button>
      </form>
    </div>
    <p class="ex-empty">Type above to find products across the store.</p>
  </div>
</section>
