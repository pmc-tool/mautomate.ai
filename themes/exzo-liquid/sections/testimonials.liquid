{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="ex-section ex-testi">
  <div class="ex-container">
    <div class="ex-shead ex-shead-center">
      <span class="ex-eyebrow">Testimonials</span>
      <h2 class="ex-title">{{ s.title | default: 'What our customers say' }}</h2>
      <span class="ex-underline"><span></span></span>
    </div>
    <div class="ex-testi-grid">
      {%- for item in items -%}
      <figure class="ex-testi-card">
        <div class="ex-testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        {%- if item.quote != blank -%}<blockquote class="ex-testi-quote">{{ item.quote }}</blockquote>{%- endif -%}
        <figcaption class="ex-testi-author">
          {%- if item.avatar != blank %}<img src="{{ item.avatar }}" alt="{{ item.author }}">{% endif -%}
          <span class="ex-testi-meta"><span class="ex-testi-name">{{ item.author }}</span>{% if item.role != blank %}<span class="ex-testi-role">{{ item.role }}</span>{% endif %}</span>
        </figcaption>
      </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
