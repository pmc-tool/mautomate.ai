{%- assign s = section.settings -%}
{%- assign width = s.width | default: 'normal' -%}
<section class="ex-section ex-richtext ex-richtext-{{ width }}">
  <div class="ex-container">
    <div class="ex-richtext-inner">{%- if s.html != blank -%}{% render 'resolve-tokens', text: s.html, shop: shop %}{%- endif -%}</div>
  </div>
</section>
