{%- comment -%} Self-contained dark Exzo footer (ex- namespace), driven by the store's chrome.footer settings. The logo sits on a light chip because tenant logos can be dark-fill transparent SVGs. {%- endcomment -%}
{%- assign root = routes.root_url -%}
{%- assign f = chrome.footer -%}
{%- assign yr = 'now' | date: '%Y' -%}
<footer class="ex-footer">
  <div class="ex-container">
    <div class="ex-footer-top">
      <div class="ex-footer-brand">
        {%- if shop.logo -%}<span class="ex-footer-logochip"><img class="ex-footer-logo" src="{{ shop.logo }}" alt="{{ shop.name }}"></span>
        {%- else -%}<div class="ex-footer-name">{{ shop.name }}</div>{%- endif -%}
        {%- if settings.footer_about != blank -%}<p class="ex-footer-about">{{ settings.footer_about }}</p>{%- endif -%}
        {%- if f.contact.phone != blank -%}<div class="ex-footer-contact"><i class="fas fa-mobile-alt"></i> <span class="ex-footer-contact-label">Contact us:</span> <span>{{ f.contact.phone }}</span></div>{%- endif -%}
        {%- if f.contact.email != blank -%}<div class="ex-footer-contact"><i class="fas fa-envelope"></i> <span class="ex-footer-contact-label">Email:</span> <a href="mailto:{{ f.contact.email }}">{{ f.contact.email }}</a></div>{%- endif -%}
        {%- if f.contact.app_buttons and f.contact.app_buttons.size > 0 -%}
        <div class="ex-footer-apps">{%- for btn in f.contact.app_buttons -%}<a href="{{ btn.href | default: '#' }}"><img src="{{ btn.img }}" alt="{{ btn.alt }}"></a>{%- endfor -%}</div>
        {%- endif -%}
      </div>

      <div class="ex-footer-col">
        <h4 class="ex-footer-title">Quick links</h4>
        <ul>
          {%- if categories -%}{%- assign lim = f.column_categories.limit | default: 5 -%}
          {%- for c in categories limit: lim -%}<li><a href="{{ root }}/categories/{{ c.handle }}">{{ c.name }}</a></li>{%- endfor -%}{%- endif -%}
          {%- if f.column_categories.extra -%}{%- for item in f.column_categories.extra -%}<li><a href="{{ item.href | default: '#' }}">{{ item.label }}</a></li>{%- endfor -%}
          {%- else -%}<li><a href="{{ routes.collections_url }}">All products</a></li>{%- endif -%}
        </ul>
      </div>

      <div class="ex-footer-col">
        <h4 class="ex-footer-title">Customer support</h4>
        <ul>
          {%- if f.column_links and f.column_links.size > 0 -%}{%- for item in f.column_links -%}<li><a href="{{ item.href | default: '#' }}">{{ item.label }}</a></li>{%- endfor -%}
          {%- else -%}<li><a href="{{ root }}/about-us">About us</a></li><li><a href="{{ root }}/contact">Contact</a></li><li><a href="{{ root }}/blog">Blog</a></li>{%- endif -%}
        </ul>
      </div>

      <div class="ex-footer-col">
        <h4 class="ex-footer-title">Stay in touch</h4>
        {%- if f.social and f.social.size > 0 -%}
        <div class="ex-footer-social">
          {%- for s in f.social -%}<a href="{{ s.href | default: '#' }}" aria-label="social"><i class="fab {{ s.icon }}"></i></a>{%- endfor -%}
        </div>
        {%- endif -%}
        <form class="ex-footer-news" data-newsletter>
          <input type="email" placeholder="{{ f.newsletter.placeholder | default: 'Your e-mail address' }}" aria-label="Email">
          <button type="submit" aria-label="Subscribe"><i class="fas fa-arrow-right"></i></button>
        </form>
      </div>
    </div>

    <div class="ex-footer-bottom">
      <p class="ex-footer-copy">{%- if f.copyright != blank -%}{{ f.copyright | replace: '{year}', yr }}{%- else -%}&copy; {{ yr }} {{ shop.name }}. {{ settings.footer_copyright | default: 'All rights reserved.' }}{%- endif -%}</p>
      {%- if f.payment_image != blank -%}<span class="ex-footer-paychip"><img class="ex-footer-pay" src="{{ f.payment_image }}" alt="Payment methods"></span>{%- endif -%}
    </div>
  </div>
</footer>
