{%- assign s = section.settings -%}
{%- assign brands = s.brands -%}
<section class="ex-section ex-brands">
  <div class="ex-container">
    {%- if s.title != blank -%}
    <div class="ex-shead ex-shead-center">
      <h2 class="ex-title ex-title-sm">{{ s.title }}</h2>
      <span class="ex-underline"><span></span></span>
    </div>
    {%- endif -%}
    {%- if brands and brands.size > 0 -%}
    <div class="ex-brand-row">
      {%- for brand in brands -%}<a class="ex-brand" href="{{ brand.href | default: '#' }}">{% if brand.image != blank %}<img src="{{ brand.image }}" alt="Brand">{% endif %}</a>{%- endfor -%}
    </div>
    {%- endif -%}
  </div>
</section>
