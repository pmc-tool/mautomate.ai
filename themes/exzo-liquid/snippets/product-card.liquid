{%- assign href = routes.root_url | append: '/products/' | append: product.handle -%}
{%- assign main = product.featured_image.url | default: product.featured_image -%}
{%- if main == blank and product.images -%}{%- assign main = product.images[0].url -%}{%- endif -%}
{%- if main == blank -%}{%- assign main = '/exzo/img/product-62.jpg' -%}{%- endif -%}
{%- assign hover = main -%}
{%- if product.images and product.images.size > 1 -%}{%- assign hover = product.images[1].url -%}{%- endif -%}
{%- assign on_sale = false -%}
{%- if product.compare_at_price and product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
<article class="ex-card">
  <div class="ex-card-media">
    {%- if on_sale -%}<span class="ex-card-badge">Sale</span>{%- endif -%}
    <a href="{{ href }}" class="ex-card-img">
      <img class="ex-card-img-main" src="{{ main | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
      {%- if hover != main and hover != blank -%}<img class="ex-card-img-hover" src="{{ hover | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">{%- endif -%}
    </a>
    <div class="ex-card-actions"><a class="ex-btn ex-btn-sm" href="{{ href }}">View product</a></div>
  </div>
  <div class="ex-card-body">
    <h3 class="ex-card-title"><a href="{{ href }}">{{ product.title }}</a></h3>
    <div class="ex-card-price">
      {%- if on_sale -%}<span class="ex-price-now ex-price-sale">{{ product.price | money }}</span> <span class="ex-price-old">{{ product.compare_at_price | money }}</span>
      {%- else -%}<span class="ex-price-now">{{ product.price | money }}</span>{%- endif -%}
    </div>
  </div>
</article>
