<section class="rk-crumbband">
  <div class="rk-container">
    <h1 class="rk-crumb-title">Shop</h1>
    <ul class="rk-crumb-menu">
      <li><a href="{{ routes.root_url }}">Home</a></li>
      <li><span class="rk-crumb-active">Shop</span></li>
    </ul>
  </div>
</section>
<section class="rk-section">
  <div class="rk-container">
    <div class="rk-shead rk-shead-center">
      <h2 class="rk-title rk-title-accent">Shop All</h2>
      <p class="rk-lead">Everything we sell, in one place.</p>
    </div>
    {%- if products and products.size > 0 -%}
    <div class="rk-grid">{%- for product in products -%}{% render 'product-card', product: product %}{%- endfor -%}</div>
    {%- else -%}<p class="rk-empty">No products yet — check back soon.</p>{%- endif -%}
  </div>
</section>
