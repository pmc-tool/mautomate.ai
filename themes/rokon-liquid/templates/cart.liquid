<section class="rk-crumbband">
  <div class="rk-container">
    <h1 class="rk-crumb-title">Shopping Cart</h1>
    <ul class="rk-crumb-menu">
      <li><a href="{{ routes.root_url }}">Home</a></li>
      <li><span class="rk-crumb-active">Shopping Cart</span></li>
    </ul>
  </div>
</section>
<section class="rk-section rk-cartpage" data-cart-page>
  <div class="rk-container">
    {%- if cart.items and cart.items.size > 0 -%}
    <div class="rk-cart-layout">
      <div class="rk-cart-lines">
        <span class="rk-count rk-cart-countline">{{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %} in your cart</span>
        {%- for item in cart.items -%}
        <article class="rk-cart-item" data-cart-line="{{ item.id }}">
          <a class="rk-cart-thumb" href="{{ routes.root_url }}{{ item.url }}">
            {%- if item.image -%}<img src="{{ item.image }}" alt="{{ item.title }}">{%- endif -%}
          </a>
          <div class="rk-cart-info">
            <a class="rk-cart-name" href="{{ routes.root_url }}{{ item.url }}">{{ item.title }}</a>
            {%- if item.variant.title != blank and item.variant.title != "Default Variant" -%}
            <span class="rk-cart-variant">{{ item.variant.title }}</span>
            {%- endif -%}
            <span class="rk-cart-unit">{{ item.unit_price | money }} each</span>
          </div>
          <span class="rk-qtybox rk-cart-qty">
            <button type="button" data-qty-minus aria-label="Decrease quantity">&minus;</button>
            <input type="text" inputmode="numeric" value="{{ item.quantity }}" data-qty-input aria-label="Quantity">
            <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
          </span>
          <span class="rk-cart-linetotal">{{ item.line_price | money }}</span>
          <button type="button" class="rk-cart-x" data-line-remove aria-label="Remove {{ item.title }}">&times;</button>
        </article>
        {%- endfor -%}
        <p class="rk-cart-msg" data-cart-msg hidden></p>
      </div>
      <aside class="rk-cart-summary">
        <h2 class="rk-cart-summary-title">Order Summary</h2>
        <div class="rk-cart-sum-row"><span>Subtotal</span><span>{{ cart.subtotal_price | money }}</span></div>
        {%- if cart.discount_total > 0 -%}
        <div class="rk-cart-sum-row rk-cart-discount"><span>Discount</span><span>&minus;{{ cart.discount_total | money }}</span></div>
        {%- endif -%}
        <div class="rk-cart-sum-row rk-cart-total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
        <form class="rk-promo" data-promo-form>
          <input type="text" name="code" placeholder="Promo code" autocomplete="off" aria-label="Promo code">
          <button type="submit">Apply</button>
        </form>
        {%- for promo in cart.promotions -%}
          {%- if promo.code != blank and promo.is_automatic != true -%}
          <div class="rk-promo-tag">
            <span>{{ promo.code }}</span>
            <button type="button" data-promo-remove="{{ promo.code }}" aria-label="Remove code {{ promo.code }}">&times;</button>
          </div>
          {%- endif -%}
        {%- endfor -%}
        <p class="rk-cart-msg" data-promo-msg hidden></p>
        <a class="rk-btn rk-btn-block" href="{{ cart.checkout_url }}">Proceed To Checkout</a>
        <a class="rk-cart-continue" href="{{ routes.collections_url }}">Continue shopping</a>
      </aside>
    </div>
    {%- else -%}
    <div class="rk-cart-empty"><p>Your cart is empty.</p><a class="rk-btn" href="{{ routes.collections_url }}">Start shopping</a></div>
    {%- endif -%}
  </div>
</section>
