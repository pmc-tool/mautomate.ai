{%- if page.sections and page.sections.size > 0 -%}
  {%- for section in page.sections -%}{% render_section section %}{%- endfor -%}
{%- else -%}
  <section class="rk-section"><div class="rk-container rk-shead rk-shead-center"><h1 class="rk-title">{{ shop.name }}</h1><p class="rk-lead">Your storefront is ready. Add sections in the editor to build your home page.</p></div></section>
{%- endif -%}
