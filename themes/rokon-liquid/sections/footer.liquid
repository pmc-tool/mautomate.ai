{%- comment -%} Self-contained Rokon footer (rk- namespace): dark ground, Work Sans widget titles, red accents. Driven by the store's chrome.footer settings. {%- endcomment -%}
{%- assign root = routes.root_url -%}
{%- assign f = chrome.footer -%}
{%- assign yr = 'now' | date: '%Y' -%}
<footer class="rk-footer">
  <div class="rk-container">
    <div class="rk-footer-top">
      <div class="rk-footer-brand">
        {%- if shop.logo -%}<img class="rk-footer-logo" src="{{ shop.logo }}" alt="{{ shop.name }}">
        {%- else -%}<div class="rk-footer-name">{{ shop.name }}</div>{%- endif -%}
        {%- if settings.footer_about != blank -%}<p class="rk-footer-about">{{ settings.footer_about }}</p>{%- endif -%}
        {%- if f.contact.email != blank -%}<a class="rk-footer-contact" href="mailto:{{ f.contact.email }}">{{ f.contact.email }}</a>{%- endif -%}
        {%- if f.contact.phone != blank -%}<span class="rk-footer-contact">{{ f.contact.phone }}</span>{%- endif -%}
        {%- if f.social and f.social.size > 0 -%}
        <div class="rk-footer-social">
          {%- for s in f.social -%}<a href="{{ s.href | default: '#' }}" aria-label="social"><i class="fab {{ s.icon }}"></i></a>{%- endfor -%}
        </div>
        {%- endif -%}
        {%- if f.contact.app_buttons and f.contact.app_buttons.size > 0 -%}
        <div class="rk-footer-apps">{%- for btn in f.contact.app_buttons -%}<a href="{{ btn.href | default: '#' }}"><img src="{{ btn.img }}" alt="{{ btn.alt }}"></a>{%- endfor -%}</div>
        {%- endif -%}
      </div>

      <div class="rk-footer-col">
        <h4 class="rk-footer-title">Quick Links</h4>
        <ul>
          {%- if categories -%}{%- assign lim = f.column_categories.limit | default: 5 -%}
          {%- for c in categories limit: lim -%}<li><a href="{{ root }}/categories/{{ c.handle }}">{{ c.name }}</a></li>{%- endfor -%}{%- endif -%}
          {%- if f.column_categories.extra -%}{%- for item in f.column_categories.extra -%}<li><a href="{{ item.href | default: '#' }}">{{ item.label }}</a></li>{%- endfor -%}
          {%- else -%}<li><a href="{{ routes.collections_url }}">All Products</a></li>{%- endif -%}
        </ul>
      </div>

      <div class="rk-footer-col">
        <h4 class="rk-footer-title">Account Info</h4>
        <ul>
          {%- if f.column_links and f.column_links.size > 0 -%}{%- for item in f.column_links -%}<li><a href="{{ item.href | default: '#' }}">{{ item.label }}</a></li>{%- endfor -%}
          {%- else -%}<li><a href="{{ root }}/about-us">About us</a></li><li><a href="{{ root }}/contact">Contact</a></li><li><a href="{{ root }}/blog">Blog</a></li>{%- endif -%}
        </ul>
      </div>

      <div class="rk-footer-col rk-footer-news-col">
        <h4 class="rk-footer-title">{{ f.newsletter.title | default: 'Newsletter' }}</h4>
        <p class="rk-footer-news-desc">Get updates by subscribing to our weekly newsletter</p>
        <form class="rk-footer-news" data-newsletter>
          <input type="email" placeholder="{{ f.newsletter.placeholder | default: 'Enter your e-mail address' }}" aria-label="Email">
          <button type="submit" class="rk-footer-news-btn">{{ f.newsletter.button | default: 'Subscribe' }}</button>
        </form>
      </div>
    </div>

    <div class="rk-footer-bottom">
      <p class="rk-footer-copy">{%- if f.copyright != blank -%}{{ f.copyright | replace: '{year}', yr }}{%- else -%}&copy; {{ yr }} {{ shop.name }}. All rights reserved.{%- endif -%}</p>
      {%- if f.payment_image != blank -%}<img class="rk-footer-pay" src="{{ f.payment_image }}" alt="Payment methods">{%- endif -%}
    </div>
  </div>
</footer>
