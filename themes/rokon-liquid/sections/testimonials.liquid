{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="rk-section rk-testi">
  <div class="rk-container">
    <div class="rk-shead rk-shead-center">
      <h2 class="rk-title rk-title-accent" data-el="title">{{ s.title | default: 'What our customers say' }}</h2>
    </div>
    <div class="rk-testi-grid">
      {%- for item in items -%}
      <figure class="rk-testi-card" data-el="item" data-el-item="items:{{ forloop.index0 }}">
        <span class="rk-testi-quote-ic" aria-hidden="true"><i class="fas fa-quote-left"></i></span>
        {%- if item.avatar -%}<img class="rk-testi-avatar" src="{{ item.avatar }}" alt="{{ item.author }}">{%- endif -%}
        {%- if item.quote != blank -%}<blockquote class="rk-testi-quote">{{ item.quote }}</blockquote>{%- endif -%}
        <figcaption class="rk-testi-author">
          <span class="rk-testi-name">{{ item.author }}</span>
          {%- if item.role != blank -%}<span class="rk-testi-role">{{ item.role }}</span>{%- endif -%}
        </figcaption>
      </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
