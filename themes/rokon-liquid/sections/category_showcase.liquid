{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="rk-section rk-showcase">
  <div class="rk-container">
    <div class="rk-shead rk-shead-center">
      {%- if s.title != blank -%}<h2 class="rk-title rk-title-accent" data-el="title">{{ s.title }}</h2>{%- endif -%}
      {%- if s.sub_title != blank -%}<p class="rk-lead">{{ s.sub_title }}</p>{%- endif -%}
    </div>
    <div class="rk-showcase-grid">
      {%- for item in items -%}
      <a class="rk-showcase-tile" data-el="tile" data-el-item="items:{{ forloop.index0 }}" href="{{ item.href | default: '/store' }}">
        <span class="rk-showcase-img">{% if item.image %}<img src="{{ item.image }}" alt="{{ item.label }}">{% endif %}</span>
        <span class="rk-showcase-cap">
          <span class="rk-showcase-txt">
            <span class="rk-showcase-label" data-el="label">{{ item.label }}</span>
            {%- if item.count != blank -%}<span class="rk-showcase-count">{{ item.count }} Items</span>{%- endif -%}
          </span>
          <span class="rk-showcase-arrow" aria-hidden="true">
            <svg viewBox="0 0 512 512" width="15" height="15"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="48" d="M268 112l144 144-144 144M392 256H100"></path></svg>
          </span>
        </span>
      </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
