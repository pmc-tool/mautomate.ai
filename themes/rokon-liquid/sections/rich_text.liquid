{%- assign s = section.settings -%}
{%- assign width = s.width | default: 'normal' -%}
<section class="rk-section rk-richtext rk-richtext-{{ width }}">
  <div class="rk-container">
    <div class="rk-richtext-inner" data-el="content">{%- if s.html != blank -%}{% render 'resolve-tokens', text: s.html, shop: shop %}{%- endif -%}</div>
  </div>
</section>
