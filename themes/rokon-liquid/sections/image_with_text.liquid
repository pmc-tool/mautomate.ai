{%- assign s = section.settings -%}
{%- assign nl = '
' -%}
{%- if s.image != blank or s.title != blank -%}
<section class="rk-section rk-imgtext{% if s.image_side == 'right' %} rk-imgtext-right{% endif %}">
  <div class="rk-container">
    <div class="rk-imgtext-grid">
      <div class="rk-imgtext-media">{% if s.image %}<img data-el="image" src="{{ s.image }}" alt="{{ s.title }}">{% endif %}</div>
      <div class="rk-imgtext-body">
        {%- if s.eyebrow != blank -%}<span class="rk-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.title != blank -%}<h2 class="rk-title" data-el="heading">{%- assign lines = s.title | split: nl -%}{%- for line in lines -%}{{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}{%- endfor -%}</h2>{%- endif -%}
        {%- if s.body != blank -%}<p class="rk-imgtext-copy" data-el="text">{{ s.body }}</p>{%- endif -%}
        {%- if s.cta.href != blank -%}<a class="rk-btn" data-el="button" href="{{ s.cta.href }}">{{ s.cta.label | default: 'Shop Now' }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>
{%- endif -%}
