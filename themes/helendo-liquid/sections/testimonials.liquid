{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="hl-section hl-testi">
  <div class="hl-container">
    <div class="hl-shead hl-shead-center">
      <h2 class="hl-title hl-title-center">{{ s.title | default: 'What our customers say' }}</h2>
    </div>
    <div class="hl-testi-grid">
      {%- for item in items -%}
      <figure class="hl-testi-card">
        <div class="hl-testi-stars">{%- for i in (1..5) -%}<i class="fas fa-star"></i>{%- endfor -%}</div>
        {%- if item.quote != blank -%}<blockquote class="hl-testi-quote">{{ item.quote }}</blockquote>{%- endif -%}
        <figcaption class="hl-testi-author">
          {%- if item.avatar %}<img src="{{ item.avatar }}" alt="{{ item.author }}">{% endif -%}
          <span class="hl-testi-name">{{ item.author }}</span>
          {%- if item.role != blank -%}<span class="hl-testi-role">{{ item.role }}</span>{%- endif -%}
        </figcaption>
      </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
