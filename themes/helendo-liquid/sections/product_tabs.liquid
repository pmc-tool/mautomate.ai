{%- assign tabs = section.settings.tabs -%}
{%- if tabs and tabs.size > 0 -%}
<section class="hl-section hl-tabs" data-tabs>
  <div class="hl-container">
    <div class="hl-shead hl-shead-center">
      <h2 class="hl-title hl-title-center">{{ section.settings.title | default: 'Best Selling' }}</h2>
      {%- if tabs.size > 1 -%}
      <nav class="hl-tabnav" role="tablist">
        {%- for tab in tabs -%}
        <button class="hl-tabbtn{% if forloop.first %} is-active{% endif %}" data-tab-btn="{{ forloop.index0 }}" role="tab">{{ tab.label }}</button>
        {%- endfor -%}
      </nav>
      {%- endif -%}
    </div>
    {%- for tab in tabs -%}
    <div class="hl-tabpanel{% if forloop.first %} is-active{% endif %}" data-tab-panel="{{ forloop.index0 }}" role="tabpanel">
      {%- assign products = tab.products -%}
      {%- if products and products.size > 0 -%}
      <div class="hl-grid">{%- for product in products -%}{% render 'product-card', product: product %}{%- endfor -%}</div>
      {%- else -%}
      <p class="hl-empty">No products to show here yet.</p>
      {%- endif -%}
    </div>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}
