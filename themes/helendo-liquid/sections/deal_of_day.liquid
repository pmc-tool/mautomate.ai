{%- assign s = section.settings -%}
<section class="hl-deal"{% if s.image %} style="background-image:url('{{ s.image }}')"{% endif %}>
  <div class="hl-container">
    <div class="hl-deal-inner">
      <h2 class="hl-title">{{ s.title | default: 'Deal of the day' }}</h2>
      {%- if s.description != blank -%}<p class="hl-deal-desc">{{ s.description }}</p>{%- endif -%}
      <div class="hl-countdown" data-countdown="{{ s.countdown_to }}">
        <div class="hl-cd"><span class="hl-cd-num" data-cd="days">00</span><span class="hl-cd-lbl">Days</span></div>
        <div class="hl-cd"><span class="hl-cd-num" data-cd="hours">00</span><span class="hl-cd-lbl">Hours</span></div>
        <div class="hl-cd"><span class="hl-cd-num" data-cd="minutes">00</span><span class="hl-cd-lbl">Mints</span></div>
        <div class="hl-cd"><span class="hl-cd-num" data-cd="seconds">00</span><span class="hl-cd-lbl">Secs</span></div>
      </div>
      {%- if s.cta.href != blank -%}<a class="hl-btn" href="{{ s.cta.href }}">{{ s.cta.label | default: 'Shop now' }} <i class="fas fa-arrow-right"></i></a>{%- endif -%}
    </div>
  </div>
</section>
