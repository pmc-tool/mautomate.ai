{
  "id": "helendo-liquid",
  "name": "Helendo",
  "version": "1.0.0",
  "engine": "1",
  "author": "mAutomate",
  "description": "Helendo — a minimal, gallery-like furniture and decor storefront. Roboto typography, generous whitespace, black buttons and the signature gold underline. Ported from the Helendo React theme to the upload engine as a fully self-contained Liquid package.",
  "tokens": {
    "colors": {
      "primary": "#dcb14a",
      "dark": "#000000",
      "text": "#666666",
      "border": "#ededed",
      "bg": "#ffffff"
    },
    "fonts": {
      "heading": "Roboto, sans-serif",
      "body": "Roboto, sans-serif"
    }
  },
  "settings": [
    { "type": "header", "label": "Brand" },
    { "id": "accent_color", "type": "color", "label": "Accent colour", "default": "#dcb14a" },
    { "id": "container_width", "type": "range", "label": "Content width", "min": 1140, "max": 1440, "step": 20, "unit": "px", "default": 1200 },
    { "type": "header", "label": "Announcement bar" },
    { "id": "show_announcement", "type": "checkbox", "label": "Show announcement bar", "default": false },
    { "id": "announcement_text", "type": "text", "label": "Announcement text", "default": "Free shipping for orders over $59 !" },
    { "type": "header", "label": "Footer" },
    { "id": "footer_about", "type": "textarea", "label": "About blurb", "default": "Simple, honest objects for the modern home — designed with care and delivered to your door." },
    { "id": "footer_copyright", "type": "text", "label": "Copyright line", "default": "All rights reserved." }
  ],
  "defaultSections": [
    {
      "block_type": "hero_slider",
      "autoplay_ms": 6000,
      "slides": [
        { "image": "/helendo/images/hero/home-default-1.jpg", "subtitle": "Handmade decor", "title": "Timeless Objects\nfor Modern Homes", "cta": { "label": "Shop now", "href": "/store" } },
        { "image": "/helendo/images/hero/home-default-2.jpg", "subtitle": "New collection", "title": "Crafted Pieces\nMade to Last", "cta": { "label": "Shop now", "href": "/store" } }
      ]
    },
    {
      "block_type": "promo_banner_grid",
      "intro": {
        "title": "The house of quiet, beautiful things",
        "body": "We collect simple, well-made objects for the home — furniture, lighting and decor built from honest materials. Every piece is chosen for how it lives with you, not just how it looks.",
        "link_label": "About us",
        "href": "/store"
      },
      "sale": {
        "image": "/helendo/images/banners/hl-sb-1.jpg",
        "special_title": "Spring sale",
        "title": "Sale up to 30% off",
        "link_label": "Shop now",
        "href": "/store"
      },
      "categories": [
        { "image": "/helendo/images/banners/hl-sb-2.jpg", "title": "Home Decor", "count_label": "16 items", "href": "/store", "wide": false },
        { "image": "/helendo/images/banners/im-md-5-780x380.jpg", "title": "Furniture", "count_label": "8 items", "href": "/store", "wide": true }
      ],
      "instagram": {
        "image": "/helendo/images/banners/h-g-3.jpg",
        "sub_title": "Follow us on instagram",
        "handle": "@helendo",
        "href": "#"
      }
    },
    {
      "block_type": "product_tabs",
      "tabs": [
        { "label": "New arrivals", "source": "all", "sort": "created_at", "limit": 8 },
        { "label": "Best selling", "source": "all", "sort": "price_desc", "limit": 8 },
        { "label": "Featured", "source": "all", "sort": "created_at", "limit": 8 }
      ]
    },
    {
      "block_type": "deal_of_day",
      "title": "Deal of the day",
      "description": "A single standout piece at a serious price, refreshed while the clock runs. Built from honest materials by makers we trust — once it is gone, it is gone.",
      "image": "/helendo/images/bg/h1-countdown.jpg",
      "countdown_to": "2030-01-01T00:00:00.000Z",
      "cta": { "label": "Shop now", "href": "/store" }
    },
    {
      "block_type": "category_showcase",
      "sub_title": "Browse the rooms",
      "title": "Shop by category",
      "items": [
        { "category_id": "", "label": "Living room", "image": "/helendo/images/banners/h-g-1.jpg", "href": "/store" },
        { "category_id": "", "label": "Lighting", "image": "/helendo/images/banners/h-g-2.jpg", "href": "/store" },
        { "category_id": "", "label": "Decor", "image": "/helendo/images/banners/h-g-4.jpg", "href": "/store" },
        { "category_id": "", "label": "Kitchen", "image": "/helendo/images/banners/h-g-5.jpg", "href": "/store" }
      ]
    },
    {
      "block_type": "brand_strip",
      "title": "Our partners",
      "brands": [
        { "image": "/helendo/images/brand/partner1.jpg", "href": "#" },
        { "image": "/helendo/images/brand/partner2.jpg", "href": "#" },
        { "image": "/helendo/images/brand/partner3.jpg", "href": "#" },
        { "image": "/helendo/images/brand/partner4.jpg", "href": "#" },
        { "image": "/helendo/images/brand/partner5.jpg", "href": "#" }
      ]
    },
    {
      "block_type": "newsletter",
      "title": "Our Newsletter",
      "subtitle": "Be the first to know about new arrivals, sales and restocks.",
      "placeholder": "Your email address",
      "button": "Subscribe",
      "provider_note": "We respect your privacy. Unsubscribe at any time."
    }
  ]
}
