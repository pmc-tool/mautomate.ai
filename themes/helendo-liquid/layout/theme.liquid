<!doctype html>
<html lang="{{ request.locale | default: 'en' }}">
<head>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Prata&display=swap" rel="stylesheet">
  {%- comment -%} Font Awesome is used only for icons (search/user/cart/social).
     No Helendo template CSS is loaded — this theme is fully self-contained in
     theme.css (hl- namespace), so nothing leaks global html/body rules. {%- endcomment -%}
  <link rel="stylesheet" href="/learts/assets/css/vendor/fontawesome.min.css">
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  <style>
    :root{
      --hl-accent: {{ settings.accent_color | default: '#dcb14a' }};
      --hl-container: {{ settings.container_width | default: 1200 }}px;
    }
  </style>
</head>
<body class="template-{{ template }} hl-body">
  {% section 'header' %}
  <main id="main">
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
