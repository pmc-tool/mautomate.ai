{%- assign tabs = section.settings.tabs -%}
{%- if tabs and tabs.size > 0 -%}
<section class="gm-section gm-tabs" data-tabs>
  <div class="gm-container">
    <div class="gm-shead gm-shead-center">
      <span class="gm-eyebrow">Featured gear</span>
      <nav class="gm-tabnav" role="tablist">
        {%- for tab in tabs -%}
        <button class="gm-tabbtn{% if forloop.first %} is-active{% endif %}" data-tab-btn="{{ forloop.index0 }}" role="tab">{{ tab.label }}</button>
        {%- endfor -%}
      </nav>
    </div>
    {%- for tab in tabs -%}
    <div class="gm-tabpanel{% if forloop.first %} is-active{% endif %}" data-tab-panel="{{ forloop.index0 }}" role="tabpanel">
      {%- assign products = tab.products -%}
      {%- if products and products.size > 0 -%}
      <div class="gm-grid">{%- for product in products -%}{% render 'product-card', product: product %}{%- endfor -%}</div>
      {%- else -%}
      <p class="gm-empty">No products to show here yet.</p>
      {%- endif -%}
    </div>
    {%- endfor -%}
  </div>
</section>
{%- endif -%}
