{%- assign s = section.settings -%}
{%- assign images = s.images -%}
{%- if images and images.size > 0 -%}
<section class="gm-section gm-gallery">
  <div class="gm-container">
    {%- if s.title != blank -%}<div class="gm-shead gm-shead-center"><h2 class="gm-title" data-el="heading">{{ s.title }}</h2></div>{%- endif -%}
    <div class="gm-gallery-grid" data-el="grid">
      {%- for item in images -%}
        {%- assign src = item.image | default: item -%}
        {%- if src != blank -%}
        <figure class="gm-gallery-cell" data-el-item="items:{{ forloop.index0 }}" data-el="item"><img src="{{ src }}" alt="{{ item.alt | default: 'Gallery image' }}">{% if item.caption != blank %}<figcaption data-el="caption">{{ item.caption }}</figcaption>{% endif %}</figure>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
