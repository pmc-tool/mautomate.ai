{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- assign show_defaults = 'cat-hmd.jpg,cat-controllers.jpg,cat-glasses.jpg,cat-haptic.jpg,cat-mobile.jpg,cat-peripherals.jpg' | split: ',' -%}
{%- if items and items.size > 0 -%}
<section class="gm-section gm-showcase">
  <div class="gm-container">
    <div class="gm-shead gm-shead-center">
      {%- if s.sub_title != blank -%}<span class="gm-eyebrow">{{ s.sub_title }}</span>{%- endif -%}
      {%- if s.title != blank -%}<h2 class="gm-title" data-el="title">{{ s.title }}</h2>{%- endif -%}
    </div>
    <div class="gm-showcase-grid">
      {%- for item in items -%}
      {%- assign timg = item.image -%}
      {%- if timg == blank -%}
        {%- assign di = forloop.index0 | modulo: show_defaults.size -%}
        {%- assign timg = show_defaults[di] | asset_url -%}
      {%- endif -%}
      <a class="gm-showcase-tile" href="{{ item.href | default: '/store' }}" data-el-item="items:{{ forloop.index0 }}" data-el="tile">
        <span class="gm-showcase-img" data-el="image">{% if timg != blank %}<img src="{{ timg }}" alt="{{ item.label }}">{% endif %}</span>
        <span class="gm-showcase-label" data-el="label">{{ item.label }}</span>
        {%- if item.count != blank -%}<span class="gm-showcase-count">{{ item.count }} items</span>{%- endif -%}
      </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
