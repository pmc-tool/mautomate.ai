{%- assign s = section.settings -%}
{%- assign nl = '
' -%}
{%- if s.image != blank or s.title != blank -%}
<section class="gm-section gm-imgtext{% if s.image_side == 'right' %} gm-imgtext-right{% endif %}">
  <div class="gm-container">
    <div class="gm-imgtext-grid">
      <div class="gm-imgtext-media" data-el="image">{% if s.image %}<img src="{{ s.image }}" alt="{{ s.title }}">{% endif %}</div>
      <div class="gm-imgtext-body">
        {%- if s.eyebrow != blank -%}<span class="gm-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.title != blank -%}<h2 class="gm-title" data-el="heading">{%- assign lines = s.title | split: nl -%}{%- for line in lines -%}{{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}{%- endfor -%}</h2>{%- endif -%}
        {%- if s.body != blank -%}<p class="gm-imgtext-copy" data-el="text">{{ s.body }}</p>{%- endif -%}
        {%- if s.cta.href != blank -%}<a class="gm-btn" href="{{ s.cta.href }}" data-el="button">{{ s.cta.label | default: 'Learn more' }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>
{%- endif -%}
