{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="gm-section gm-testi">
  <div class="gm-container">
    <div class="gm-shead gm-shead-center">
      <span class="gm-eyebrow">Testimonials</span>
      <h2 class="gm-title" data-el="title">{{ s.title | default: 'What our players say' }}</h2>
    </div>
    <div class="gm-testi-grid">
      {%- for item in items -%}
      <figure class="gm-testi-card" data-el-item="items:{{ forloop.index0 }}" data-el="item">
        <div class="gm-testi-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        {%- if item.quote != blank -%}<blockquote class="gm-testi-quote" data-el="quote">{{ item.quote }}</blockquote>{%- endif -%}
        <figcaption class="gm-testi-author" data-el="author">
          {%- if item.avatar %}<img src="{{ item.avatar }}" alt="{{ item.author }}">{% endif -%}
          <span class="gm-testi-meta"><span class="gm-testi-name">{{ item.author }}</span>{% if item.role != blank %}<span class="gm-testi-role">{{ item.role }}</span>{% endif %}</span>
        </figcaption>
      </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
