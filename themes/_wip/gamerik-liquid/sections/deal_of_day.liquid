{%- assign s = section.settings -%}
<section class="gm-section gm-deal">
  <div class="gm-container">
    <div class="gm-deal-grid">
      <div class="gm-deal-media" data-el="image">
        {%- assign dimg = s.image -%}
        {%- if dimg == blank -%}{%- assign dimg = 'deal-1.jpg' | asset_url -%}{%- endif -%}
        {%- if dimg != blank %}<img src="{{ dimg }}" alt="{{ s.title | default: 'Deal of the day' }}">{% else %}<div class="gm-deal-fallback"></div>{% endif -%}
      </div>
      <div class="gm-deal-content" data-el="content">
        <span class="gm-eyebrow">Limited time</span>
        <h2 class="gm-title" data-el="title">{{ s.title | default: 'Deal of the day' }}</h2>
        {%- if s.description != blank -%}<p class="gm-deal-desc" data-el="text">{{ s.description }}</p>{%- endif -%}
        {%- comment -%} Compute the initial countdown server-side so it shows real
          numbers even before theme.js ticks (and in the editor, which has no JS).
          liquidjs divided_by is FLOAT division, so every step needs | floor. {%- endcomment -%}
        {%- assign _target = s.countdown_to | date: '%s' | plus: 0 -%}
        {%- assign _now = 'now' | date: '%s' | plus: 0 -%}
        {%- assign _diff = _target | minus: _now -%}
        {%- if _diff < 0 -%}{%- assign _diff = 0 -%}{%- endif -%}
        {%- assign _d = _diff | divided_by: 86400 | floor -%}
        {%- assign _h = _diff | modulo: 86400 | divided_by: 3600 | floor -%}
        {%- assign _m = _diff | modulo: 3600 | divided_by: 60 | floor -%}
        {%- assign _s = _diff | modulo: 60 -%}
        <div class="gm-countdown" data-el="countdown" data-countdown="{{ s.countdown_to }}">
          <div class="gm-cd"><span class="gm-cd-num" data-cd="days">{% if _d < 10 %}0{% endif %}{{ _d }}</span><span class="gm-cd-lbl">Days</span></div>
          <div class="gm-cd"><span class="gm-cd-num" data-cd="hours">{% if _h < 10 %}0{% endif %}{{ _h }}</span><span class="gm-cd-lbl">Hours</span></div>
          <div class="gm-cd"><span class="gm-cd-num" data-cd="minutes">{% if _m < 10 %}0{% endif %}{{ _m }}</span><span class="gm-cd-lbl">Mins</span></div>
          <div class="gm-cd"><span class="gm-cd-num" data-cd="seconds">{% if _s < 10 %}0{% endif %}{{ _s }}</span><span class="gm-cd-lbl">Secs</span></div>
        </div>
        {%- if s.cta.href != blank -%}<a class="gm-btn" href="{{ s.cta.href }}" data-el="button">{{ s.cta.label | default: 'Shop now' }}</a>{%- endif -%}
      </div>
    </div>
  </div>
</section>
