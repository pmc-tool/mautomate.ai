{%- assign s = section.settings -%}
{%- assign images = s.images -%}
{%- assign insta_defaults = 'insta-1.jpg,insta-2.jpg,insta-3.jpg,insta-4.jpg,insta-5.jpg,insta-6.jpg' | split: ',' -%}
{%- if images and images.size > 0 -%}
<section class="gm-section gm-insta">
  <div class="gm-container">
    {%- if s.heading != blank or s.handle != blank -%}
    <div class="gm-shead gm-shead-center">
      {%- if s.heading != blank -%}<span class="gm-eyebrow">{{ s.heading }}</span>{%- endif -%}
      {%- if s.handle != blank -%}<h2 class="gm-title" data-el="title">{{ s.handle }}</h2>{%- endif -%}
    </div>
    {%- endif -%}
    <div class="gm-insta-grid">
      {%- for item in images -%}
      {%- assign gimg = item.image -%}
      {%- if gimg == blank -%}
        {%- assign di = forloop.index0 | modulo: insta_defaults.size -%}
        {%- assign gimg = insta_defaults[di] | asset_url -%}
      {%- endif -%}
      {%- if gimg != blank -%}
      <a class="gm-insta-cell" href="{{ item.href | default: '#' }}" data-el-item="images:{{ forloop.index0 }}" data-el="item"><img src="{{ gimg }}" alt="Instagram post"><span class="gm-insta-ic"><svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3.5" y="3.5" width="17" height="17" rx="4.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg></span></a>
      {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
