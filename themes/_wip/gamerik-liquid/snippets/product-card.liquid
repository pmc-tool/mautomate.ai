{%- assign href = routes.root_url | append: '/products/' | append: product.handle -%}
{%- assign main = product.featured_image.url | default: product.featured_image -%}
{%- if main == blank and product.images -%}{%- assign main = product.images[0].url -%}{%- endif -%}
{%- if main == blank -%}{%- assign main = 'placeholder-product.jpg' | asset_url -%}{%- endif -%}
{%- assign hover = main -%}
{%- if product.images and product.images.size > 1 -%}{%- assign hover = product.images[1].url -%}{%- endif -%}
{%- assign on_sale = false -%}
{%- if product.compare_at_price and product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
<article class="gm-card">
  <div class="gm-card-media">
    {%- if on_sale -%}<span class="gm-card-badge">Sale</span>{%- endif -%}
    <a href="{{ href }}" class="gm-card-img">
      <img class="gm-card-img-main" src="{{ main }}" alt="{{ product.title }}" loading="lazy">
      {%- if hover != main -%}<img class="gm-card-img-hover" src="{{ hover }}" alt="{{ product.title }}" loading="lazy">{%- endif -%}
    </a>
  </div>
  <div class="gm-card-body">
    <h3 class="gm-card-title"><a href="{{ href }}">{{ product.title }}</a></h3>
    <div class="gm-card-price">
      {%- if on_sale -%}<span class="gm-price-old">{{ product.compare_at_price | money }}</span> <span class="gm-price-now">{{ product.price | money }}</span>
      {%- else -%}<span class="gm-price-now">{{ product.price | money }}</span>{%- endif -%}
    </div>
  </div>
</article>
