<!doctype html>
<html lang="{{ request.locale | default: 'en' }}">
<head>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  {%- comment -%} Font Awesome is used only for social / instagram glyphs (shared
     vendor file). No other theme's CSS is loaded — Aurora is fully self-contained
     in theme.css (au- namespace), so nothing leaks global html/body rules. {%- endcomment -%}
  <link rel="stylesheet" href="/learts/assets/css/vendor/fontawesome.min.css">
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  <style>
    :root{
      --au-accent: {{ settings.accent_color | default: '#111111' }};
      --au-container: {{ settings.container_width | default: 1280 }}px;
    }
  </style>
</head>
<body class="template-{{ template }} au-body">
  {% section 'header' %}
  <main id="main">
    {{ content_for_layout }}
  </main>
  {% section 'footer' %}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
