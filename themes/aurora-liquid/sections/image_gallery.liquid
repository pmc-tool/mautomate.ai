{%- assign s = section.settings -%}
{%- assign images = s.images -%}
{%- if images and images.size > 0 -%}
<section class="au-section au-gallery">
  <div class="au-container">
    {%- if s.title != blank -%}<div class="au-shead au-shead-center"><h2 class="au-title">{{ s.title }}</h2></div>{%- endif -%}
    <div class="au-gallery-grid">
      {%- for item in images -%}
        {%- assign src = item.image | default: item -%}
        {%- if src != blank -%}
        <figure class="au-gallery-cell au-card"><img src="{{ src }}" alt="{{ item.alt | default: 'Gallery image' }}">{% if item.caption != blank %}<figcaption>{{ item.caption }}</figcaption>{% endif %}</figure>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
