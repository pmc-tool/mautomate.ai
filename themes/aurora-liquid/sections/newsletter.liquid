{%- assign s = section.settings -%}
{%- if s.title != blank -%}
<section class="au-section au-newsletter">
  <div class="au-container">
    <div class="au-newsletter-card au-card">
      <p class="au-eyebrow">Newsletter</p>
      <h2 class="au-title">{{ s.title }}</h2>
      {%- if s.subtitle != blank -%}<p class="au-newsletter-sub">{{ s.subtitle }}</p>{%- endif -%}
      <form class="au-newsletter-form" data-newsletter>
        <div class="au-input-wrap">
          <i class="far fa-envelope" aria-hidden="true"></i>
          <input type="email" placeholder="{{ s.placeholder | default: 'Enter your email address' }}" aria-label="Email address" required>
        </div>
        <button type="submit" class="au-btn">{{ s.button | default: 'Subscribe' }}</button>
      </form>
      {%- if s.provider_note != blank -%}<p class="au-newsletter-note">{{ s.provider_note }}</p>{%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}
