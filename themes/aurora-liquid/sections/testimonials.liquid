{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="au-section au-testi">
  <div class="au-container">
    <div class="au-shead au-shead-center">
      <p class="au-eyebrow">Testimonials</p>
      <h2 class="au-title">{{ s.title | default: 'What our customers say' }}</h2>
    </div>
    <div class="au-testi-grid">
      {%- for item in items -%}
      <figure class="au-testi-card au-card">
        <span class="au-testi-mark">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M7.17 6A5.17 5.17 0 0 0 2 11.17V18h6.83v-6.83H5.5A1.67 1.67 0 0 1 7.17 9.5V6Zm11 0A5.17 5.17 0 0 0 13 11.17V18h6.83v-6.83H16.5a1.67 1.67 0 0 1 1.67-1.67V6Z"/></svg>
        </span>
        {%- if item.quote != blank -%}<blockquote class="au-testi-quote">{{ item.quote }}</blockquote>{%- endif -%}
        <figcaption class="au-testi-author">
          {%- if item.avatar -%}<img src="{{ item.avatar }}" alt="{{ item.author }}">
          {%- else -%}<span class="au-testi-initial">{{ item.author | slice: 0 | upcase }}</span>{%- endif -%}
          <span class="au-testi-meta"><span class="au-testi-name">{{ item.author }}</span>{% if item.role != blank %}<span class="au-testi-role">{{ item.role }}</span>{% endif %}</span>
        </figcaption>
      </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
