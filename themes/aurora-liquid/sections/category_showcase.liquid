{%- assign s = section.settings -%}
{%- assign items = s.items -%}
{%- if items and items.size > 0 -%}
<section class="au-section au-showcase">
  <div class="au-container">
    <div class="au-shead">
      {%- if s.sub_title != blank -%}<p class="au-eyebrow">{{ s.sub_title }}</p>{%- endif -%}
      {%- if s.title != blank -%}<h2 class="au-title">{{ s.title }}</h2>{%- endif -%}
    </div>
    <div class="au-showcase-grid">
      {%- for item in items -%}
      <a class="au-showcase-tile au-card" href="{{ item.href | default: '/store' }}">
        <span class="au-showcase-img">{% if item.image %}<img src="{{ item.image }}" alt="{{ item.label }}">{% endif %}</span>
        <span class="au-showcase-cap">
          <span class="au-showcase-meta">
            <span class="au-showcase-label">{{ item.label }}</span>
            {%- if item.count != blank -%}<span class="au-showcase-count">{{ item.count }} Items</span>{%- endif -%}
          </span>
          <span class="au-showcase-arrow">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </span>
        </span>
      </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
