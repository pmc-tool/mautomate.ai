{%- assign cols = section.settings.columns -%}
{%- if cols and cols.size > 0 -%}
<section class="au-section au-composed">
  <div class="au-container">
    <div class="au-composed-row" data-cols="{{ cols.size }}">
      {%- for col in cols -%}
      <div class="au-composed-col">
        {%- for w in col.widgets -%}
        <div class="au-composed-widget">
          {%- if w.image != blank -%}<img class="au-composed-img" src="{{ w.image }}" alt="{{ w.title | default: '' }}">{%- endif -%}
          {%- if w.eyebrow != blank -%}<p class="au-eyebrow">{{ w.eyebrow }}</p>{%- endif -%}
          {%- if w.title != blank -%}<h3 class="au-composed-title">{{ w.title }}</h3>{%- endif -%}
          {%- if w.html != blank -%}<div class="au-prose">{% render 'resolve-tokens', text: w.html, shop: shop %}</div>{%- endif -%}
          {%- if w.body != blank -%}<p class="au-composed-body">{{ w.body }}</p>{%- endif -%}
          {%- if w.cta.href != blank -%}<a class="au-textlink" href="{{ w.cta.href }}">{{ w.cta.label | default: 'Learn more' }}</a>{%- endif -%}
        </div>
        {%- endfor -%}
      </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
