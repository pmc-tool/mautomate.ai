{%- assign s = section.settings -%}
<section class="au-section au-deal">
  <div class="au-container">
    <div class="au-deal-card au-card">
      <div class="au-deal-media">
        {%- if s.image %}<img src="{{ s.image }}" alt="{{ s.title | default: 'Deal of the day' }}">{% else %}<div class="au-deal-fallback"></div>{% endif -%}
      </div>
      <div class="au-deal-content">
        <p class="au-eyebrow">Limited time</p>
        <h2 class="au-title">{{ s.title | default: 'Deal of the day' }}</h2>
        {%- if s.description != blank -%}<p class="au-deal-desc">{{ s.description }}</p>{%- endif -%}
        <div class="au-countdown" data-countdown="{{ s.countdown_to }}">
          <div class="au-cd"><span class="au-cd-num" data-cd="days">00</span><span class="au-cd-lbl">Days</span></div>
          <span class="au-cd-sep">:</span>
          <div class="au-cd"><span class="au-cd-num" data-cd="hours">00</span><span class="au-cd-lbl">Hours</span></div>
          <span class="au-cd-sep">:</span>
          <div class="au-cd"><span class="au-cd-num" data-cd="minutes">00</span><span class="au-cd-lbl">Minutes</span></div>
          <span class="au-cd-sep">:</span>
          <div class="au-cd"><span class="au-cd-num" data-cd="seconds">00</span><span class="au-cd-lbl">Seconds</span></div>
        </div>
        {%- assign cta_label = s.cta.label | default: 'Shop Now' -%}
        {%- if s.cta.href != blank and cta_label != blank -%}
        <a class="au-btn" href="{{ s.cta.href }}">{{ cta_label }}
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
