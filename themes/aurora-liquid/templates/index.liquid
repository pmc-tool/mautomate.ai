{%- if page.sections and page.sections.size > 0 -%}
  {%- for section in page.sections -%}{% render_section section %}{%- endfor -%}
{%- else -%}
  <section class="au-section"><div class="au-container au-shead au-shead-center"><h1 class="au-title">{{ shop.name }}</h1><p class="au-lead">Your storefront is ready. Add sections in the editor to build your home page.</p></div></section>
{%- endif -%}
