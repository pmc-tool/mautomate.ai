<section class="au-section">
  <div class="au-container">
    <div class="au-shead au-shead-center">
      <p class="au-eyebrow">Find it</p>
      <h1 class="au-title">Search</h1>
      <form class="au-search-form" action="{{ routes.search_url }}" method="get">
        <div class="au-input-wrap">
          <i class="fas fa-search" aria-hidden="true"></i>
          <input type="search" name="q" placeholder="Search products..." aria-label="Search products">
        </div>
        <button type="submit" class="au-btn">Search</button>
      </form>
    </div>
    <p class="au-empty">Type above to find products across the store.</p>
  </div>
</section>
