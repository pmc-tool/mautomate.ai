    "verify:schema": "node --experimental-strip-types --no-warnings scripts/verify-schema.ts",
    "verify:style-engine": "node --experimental-strip-types --no-warnings scripts/verify-style-engine.ts",
    "verify:render-parity": "node --experimental-strip-types --no-warnings scripts/verify-render-parity.ts"
