import { MedusaRequest, MedusaResponse } from "@medusajs/framework/http"
import { CALL_CENTER_MODULE } from "../../../../../../modules/call-center"
import CallCenterModuleService from "../../../../../../modules/call-center/service"
import { resolveMerchant } from "../../../../_helpers"
import { z } from "zod"

const isNotFound = (e: any): boolean =>
  e?.type === "not_found" || /was not found|not found/i.test(e?.message ?? "")

const CreateKnowledgeSchema = z.object({
  name: z.string().min(1),
  source_type: z
    .enum(["faq", "text", "url", "file", "product_catalog"])
    .optional()
    .default("text"),
  content: z.string().optional().nullable(),
  url: z.string().optional().nullable(),
})

/** Assert the agent exists and belongs to the caller's tenant. */
const assertOwnedAgent = async (
  cc: CallCenterModuleService,
  id: string,
  tenantId: string,
  res: MedusaResponse
): Promise<boolean> => {
  const agent = await (cc as any).retrievePlaybook(id).catch(() => null)
  if (!agent || agent.tenant_id !== tenantId) {
    res.status(404).json({ message: `Agent ${id} was not found` })
    return false
  }
  return true
}

/**
 * GET /merchant/call-center/agents/:id/knowledge
 *
 * List the agent's knowledge-base entries (newest first). Tenant-scoped.
 * Response: { knowledge, count }
 */
export const GET = async (req: MedusaRequest, res: MedusaResponse) => {
  const ctx = await resolveMerchant(req)
  if (!ctx) return res.status(401).json({ message: "not authorized" })

  const tenant_id = ctx.merchant.tenant_id
  if (!tenant_id) {
    return res.status(401).json({ message: "merchant tenant not resolved" })
  }

  const { id } = req.params

  try {
    const cc: CallCenterModuleService = req.scope.resolve(CALL_CENTER_MODULE)

    if (!(await assertOwnedAgent(cc, id, tenant_id, res))) return

    const [knowledge, count] = await (cc as any).listAndCountKnowledgeEntries(
      { tenant_id, agent_id: id },
      { take: 500, order: { created_at: "DESC" } }
    )

    res.json({ knowledge, count })
  } catch (e: any) {
    res.status(isNotFound(e) ? 404 : 500).json({
      message: e?.message ?? "Failed to list knowledge",
    })
  }
}

/**
 * POST /merchant/call-center/agents/:id/knowledge
 *
 * Attach a knowledge-base entry to an agent (storage only; embedding/RAG is
 * key-gated and wired later). Tenant-scoped, tenant_id tagged on create.
 * Body: { name, source_type?, content?, url? }
 * Response: { knowledge }
 */
export const POST = async (req: MedusaRequest, res: MedusaResponse) => {
  const ctx = await resolveMerchant(req)
  if (!ctx) return res.status(401).json({ message: "not authorized" })

  const tenant_id = ctx.merchant.tenant_id
  if (!tenant_id) {
    return res.status(401).json({ message: "merchant tenant not resolved" })
  }

  const { id } = req.params

  const parsed = CreateKnowledgeSchema.safeParse(req.body)
  if (!parsed.success) {
    return res
      .status(400)
      .json({ message: "invalid input", issues: parsed.error.issues })
  }

  try {
    const cc: CallCenterModuleService = req.scope.resolve(CALL_CENTER_MODULE)

    if (!(await assertOwnedAgent(cc, id, tenant_id, res))) return

    const knowledge = await (cc as any).createKnowledgeEntries({
      tenant_id,
      agent_id: id,
      name: parsed.data.name,
      source_type: parsed.data.source_type,
      content: parsed.data.content ?? null,
      url: parsed.data.url ?? null,
    })

    res.status(201).json({ knowledge })
  } catch (e: any) {
    res.status(isNotFound(e) ? 404 : 500).json({
      message: e?.message ?? "Failed to create knowledge",
    })
  }
}
