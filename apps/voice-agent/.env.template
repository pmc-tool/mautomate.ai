# mAutomate voice-agent runtime — environment
# Copy to `.env` and fill in. The lead injects these on the pm2 process.

# --- Service / auth ---------------------------------------------------------
# Shared secret the backend sends as `x-api-key` on POST /api/pipelines/start|stop.
VOICE_AGENT_API_KEY=
# Port uvicorn binds (loopback). Must match the backend's VOICE_AGENT_URL.
VOICE_AGENT_PORT=8790

# --- Control plane (Medusa backend) -----------------------------------------
# Base URL of the Medusa backend, WITHOUT a trailing /telephony.
# e.g. http://127.0.0.1:9000
MEDUSA_BACKEND_URL=
# Must equal the backend's TELEPHONY_WEBHOOK_SECRET — sent as `x-telephony-secret`
# on every /telephony/* call (agent-config, tool-execute, call-ended).
TELEPHONY_WEBHOOK_SECRET=

# --- Media providers --------------------------------------------------------
# Daily: used to mint a meeting token for the (already-created) room.
DAILY_API_KEY=
# Optional override; defaults to https://api.daily.co/v1
DAILY_API_URL=https://api.daily.co/v1

# Deepgram streaming STT.
DEEPGRAM_API_KEY=

# OpenAI LLM (+ optional end-of-call summary).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ElevenLabs TTS.
ELEVENLABS_API_KEY=
# Fallback voice id used when the playbook ships a placeholder voice_id
# (e.g. "bn-female-warm") that is not a real ElevenLabs voice.
ELEVENLABS_VOICE_ID=

# --- Safety / behaviour (optional) ------------------------------------------
# Hard wall-clock cap per call, seconds (watchdog force-ends stuck calls).
VOICE_AGENT_MAX_CALL_SECONDS=600
# Name the bot shows as in the Daily room.
VOICE_AGENT_BOT_NAME=AI Agent
# INFO | DEBUG | WARNING | ERROR
VOICE_AGENT_LOG_LEVEL=INFO
# Generate a 1-2 sentence LLM summary at hangup (posted as call-ended.summary).
VOICE_AGENT_GENERATE_SUMMARY=true

# --- Naturalness tuning (all optional; defaults shown) ---
# ELEVENLABS_MODEL=eleven_flash_v2_5      # eleven_turbo_v2_5 for more polish at higher latency
# VOICE_TTS_STABILITY=0.5                 # ElevenLabs voice stability (0-1)
# VOICE_TTS_SIMILARITY=0.75               # ElevenLabs similarity boost (0-1)
# VOICE_TTS_STYLE=0.0                     # expressiveness; >0 costs latency
# VOICE_TTS_SPEED=                        # 0.7-1.2; empty = provider default
# VOICE_VAD_STOP_SECS=0.5                 # silence before end-of-turn (the response-gap knob)
# VOICE_VAD_START_SECS=0.15
# VOICE_VAD_CONFIDENCE=0.6
# VOICE_VAD_MIN_VOLUME=0.4
# VOICE_SMART_TURN=false                  # semantic turn model; needs torch + a CPU with AVX2 (or GPU)
# VOICE_SMART_TURN_STOP_SECS=2.0
# VOICE_SMART_TURN_MODEL_PATH=
# VOICE_IDLE_ENABLED=true
# VOICE_IDLE_TIMEOUT_SECS=10
# VOICE_TOOL_FILLERS=true                 # spoken "one sec..." while tools run
# VOICE_INTERRUPT_MIN_WORDS=0             # require N words before barge-in stops the bot (phone lines)
# VOICE_LLM_TEMPERATURE=0.7
# VOICE_FILLER_DELAY_SECS=0.4             # filler speaks only if a tool is slower than this
# VOICE_PREWARM_JOIN_TIMEOUT_SECS=300     # pre-warmed bot waits this long for a human, then exits unbilled
# VOICE_REALTIME=false                    # speech-to-speech pilot (OpenAI Realtime) for ALL web calls
# VOICE_REALTIME_AGENTS=                  # ...or pilot per playbook id (comma-separated)
# VOICE_REALTIME_MODEL=gpt-realtime
# VOICE_REALTIME_VOICE=marin
